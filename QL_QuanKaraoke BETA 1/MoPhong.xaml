<Window x:Class="QL_QuanKaraoke_BETA_1.MoPhong"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QL_QuanKaraoke_BETA_1"
        mc:Ignorable="d"
        Title="MoPhong" Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1A1825" WindowStyle="None" Name="DatPhongWD" DataContext="{StaticResource MoPhongVM}">
    <Border Padding="28,24,28,28">

        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="0" Opacity="0.6"/>
        </Border.Effect>

        <StackPanel>
            <Button HorizontalAlignment="Right"
                    Style="{StaticResource CloseButtonStyle }"
                    Command="{Binding CloseWindowCommand}"
                    CommandParameter="{Binding ElementName=DatPhongWD}"/>

            <!-- ── Tiêu đề ── -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="🎤"
                           FontSize="20"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <TextBlock Text="Thông tin đặt phòng"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- ── Đường kẻ ngang ── -->
            <Separator Background="#2E2B47" Margin="0,0,0,20"/>

            <!-- ══════════════════════════════════════
                 PHẦN 1: Số điện thoại + Auto Fill
            ══════════════════════════════════════ -->
            <TextBlock Text="Số điện thoại"
                       Foreground="#9490B0"
                       FontSize="12"
                       Margin="0,0,0,6"/>


            <Border Background="#353340"
                        CornerRadius="8"
                        Height="46"
                        Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="44"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="1"
                            x:Name="TxtSoDienThoai"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#E6E6E6"
                            FontSize="14"
                            VerticalContentAlignment="Center"
                            Tag="Số điện thoại"
                            Style="{StaticResource TextBoxTheme}"
                            Text="{Binding SoDienThoai, UpdateSourceTrigger=PropertyChanged}"
                            IsEnabled="{Binding IsEditable}"/>
                </Grid>

            </Border>

            <!--Nút Auto Fill-->
            <Button Height="46"
                    Cursor="Hand"
                    BorderThickness="0" 
                    Command="{Binding AutoFillCommand}">

                <Button.Template>
                    <ControlTemplate TargetType="Button">

                        <Border x:Name="ConfirmBorder"
                                CornerRadius="8"
                                Height="46">

                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#F07070" Offset="0"/>
                                    <GradientStop Color="#F9A8A8" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>

                            <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                                <TextBlock Text="✔"
                               Foreground="White"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>

                                <TextBlock Text="AUTO FILL"
                               Foreground="White"
                               FontSize="14"
                               FontWeight="Bold"
                               FontFamily="Segoe UI"
                               VerticalAlignment="Center"/>
                            </StackPanel>

                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ConfirmBorder"
                            Property="Opacity"
                            Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ConfirmBorder"
                            Property="Opacity"
                            Value="0.72"/>
                            </Trigger>
                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Button.Template>

            </Button>

            <TextBlock Text="Họ tên"
                       Foreground="#9490B0"
                       FontSize="12"
                       Margin="0,10,0,6"/>

            <Border Background="#353340"
                    CornerRadius="8"
                    Height="46"
                    Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="44"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="1"
                             Background="Transparent"
                             BorderThickness="0"
                            Foreground="#E6E6E6"
                            FontSize="14"
                           VerticalContentAlignment="Center"
                           Tag="Họ tên"
                            Style="{StaticResource TextBoxTheme}"
                             Text="{Binding HoTen, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding IsEditable}"/>
                </Grid>

            </Border>

            <!-- ══════════════════════════════════════
                 PHẦN 3: Hạng thành viên
            ══════════════════════════════════════ -->
            <TextBlock Text="Hạng thành viên"
                       Foreground="#9490B0"
                       FontSize="12"
                       Margin="0,0,0,6"/>

            <Border Background="#353340"
                   CornerRadius="8"
                    Height="46"
                    Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="44"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="1"
                               Background="Transparent"
                                BorderThickness="0"
                                Foreground="#E6E6E6"
                                FontSize="14"
                                VerticalContentAlignment="Center"
                                Tag="Hạng thành viên"
                                Style="{StaticResource TextBoxTheme}"
                             Text="{Binding HangThanhVien, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding IsEditable}"/>
                </Grid>

            </Border>

            <!-- ══════════════════════════════════════
                 PHẦN 4: Phần trăm giảm giá
            ══════════════════════════════════════ -->
            <TextBlock Text="Phần trăm giảm giá"
                       Foreground="#9490B0"
                       FontSize="12"
                       Margin="0,0,0,6"/>

            <Border Background="#353340"
            CornerRadius="8"
            Height="46"
            Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="44"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="1"
                Background="Transparent"
                BorderThickness="0"
                Foreground="#E6E6E6"
                FontSize="14"
                VerticalContentAlignment="Center"
                Tag="Phần trăm giảm giá"
                Style="{StaticResource TextBoxTheme}"
                             Text="{Binding PhanTramGiamGia, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding IsEditable}"/>
                </Grid>

            </Border>

            <Button Height="46"
                    Cursor="Hand"
                    BorderThickness="0"
                    Command="{Binding XacNhanCommand}"
                    CommandParameter="{Binding ElementName=DatPhongWD}"
                    >

                <Button.Template>
                    <ControlTemplate TargetType="Button">

                        <Border x:Name="ConfirmBorder"
                     CornerRadius="8"
                     Height="46">

                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#F07070" Offset="0"/>
                                    <GradientStop Color="#F9A8A8" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>

                            <StackPanel Orientation="Horizontal"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center">

                                <TextBlock Text="✔"
                    Foreground="White"
                    FontSize="14"
                    VerticalAlignment="Center"
                    Margin="0,0,8,0"/>

                                <TextBlock Text="XÁC NHẬN"
                    Foreground="White"
                    FontSize="14"
                    FontWeight="Bold"
                    FontFamily="Segoe UI"
                    VerticalAlignment="Center"/>
                            </StackPanel>

                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ConfirmBorder"
                 Property="Opacity"
                 Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ConfirmBorder"
                 Property="Opacity"
                 Value="0.72"/>
                            </Trigger>
                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Button.Template>

            </Button>

        </StackPanel>
    </Border>

</Window>
