<Window x:Class="QL_QuanKaraoke_BETA_1.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QL_QuanKaraoke_BETA_1.ClassTheme"
        mc:Ignorable="d"
        Title="LoginWindow"
        WindowStartupLocation="CenterScreen"
        DataContext="{StaticResource LoginVM}"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="CanResize"
        Height="480"
        Width="820" 
        Name="LoginWD" AllowsTransparency="True" MouseLeftButtonDown="LoginWD_MouseLeftButtonDown">

    <Border CornerRadius="20" Background="#1A1A2E">
        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="16,0,0,16">
                <Grid>

                    <Image Source="/image/KaraokeLogo.png"
                           Stretch="Fill" />

                    <StackPanel VerticalAlignment="Top" Margin="36,36,36,0">
                        <TextBlock Text="PHẦN MỀM"
                                   Foreground="White"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   FontFamily="Segoe UI"/>

                        <TextBlock Text="QUẢN LÝ QUÁN KARAOKE"
                                   Foreground="White"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   FontFamily="Segoe UI"/>
                    </StackPanel>

                </Grid>
            </Border>


            <Border Grid.Column="1"
                    CornerRadius="0,16,16,0"
                    Background="#1A1A2E">

                <Grid>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,12,12,0">

                        <Button Style="{StaticResource MinimizeButtonStyle}"
                                Command="{Binding MinimizeCommand}"
                                CommandParameter="{Binding ElementName=LoginWD}"/>

                        <Button Style="{StaticResource MaximizeButtonStyle}"
                                Command="{Binding MaximizeCommand}"
                                CommandParameter="{Binding ElementName=LoginWD}"/>

                        <Button Style="{StaticResource CloseButtonStyle}"
                                Command="{Binding ExitCommand}"
                                CommandParameter="{Binding ElementName=LoginWD}"/>
                    </StackPanel>


                    <!-- FORM LOGIN -->
                    <StackPanel VerticalAlignment="Center" Margin="40,0,40,0">

                        <TextBlock Text="CHÀO MỪNG"
                                   Foreground="#F07070"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   FontFamily="Segoe UI"/>

                        <TextBlock Text="TRỞ LẠI VỚI ROYAL KARAOKE"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   FontFamily="Segoe UI"
                                   Margin="0,4,0,36"/>


                        <!-- USERNAME -->
                        <Border Background="#353340"
                                CornerRadius="8"
                                Height="46"
                                Margin="0,0,0,14">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>

                                <Image Width="18"
                                       Height="18"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Source="/image/person.png"/>

                                <TextBox Grid.Column="1" Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="#E6E6E6"
                                         FontSize="14"
                                         VerticalContentAlignment="Center"
                                         Padding="4,0,10,0"
                                         Style="{StaticResource TextBoxTheme}"
                                         Tag="Username"/>
                            </Grid>

                        </Border>


                        <!-- PASSWORD -->
                        <Border Background="#353340"
                                CornerRadius="8"
                                Height="46"
                                Margin="0,0,0,28">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>

                                <Image Source="/image/padlock.png"
                                       Width="16"
                                       Height="18"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>

                                <PasswordBox Grid.Column="1"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             FontSize="13"
                                             FontFamily="Segoe UI"
                                             VerticalContentAlignment="Center"
                                             x:Name="TxtPassword"
                                             Style="{StaticResource PasswordBoxTheme}"
                                             Tag="Password"
                                             local:PasswordHelper.MonitorPassword="True"
                                             >
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="PasswordChanged">
                                            <i:InvokeCommandAction Command="{Binding PasswordChangedCommand}" CommandParameter="{Binding ElementName=TxtPassword}" />
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                </PasswordBox>
                                
                            </Grid>
                        </Border>

                        

                        <!-- BUTTON LOGIN -->
                        <Button Height="46"
                                Cursor="Hand"
                                BorderThickness="0" Command="{Binding LoginCommand}"
                                CommandParameter="{Binding ElementName=LoginWD}"
                                >

                            <Button.Template>
                                <ControlTemplate TargetType="Button">

                                    <Border x:Name="LoginBorder"
                                            CornerRadius="8"
                                            Height="46">

                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#F07070" Offset="0"/>
                                                <GradientStop Color="#F9A8A8" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>

                                        <TextBlock Text="ĐĂNG NHẬP"
                                                   Foreground="White"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   FontFamily="Segoe UI"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>

                                    </Border>

                                    <ControlTemplate.Triggers>

                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="LoginBorder"
                                                    Property="Opacity"
                                                    Value="0.88"/>
                                        </Trigger>

                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="LoginBorder"
                                                    Property="Opacity"
                                                    Value="0.72"/>
                                        </Trigger>

                                    </ControlTemplate.Triggers>

                                </ControlTemplate>
                            </Button.Template>

                        </Button>

                        <TextBlock Text="Quên mật khẩu ?"
                                   Foreground="#F07070"
                                   FontSize="12"
                                   FontFamily="Segoe UI"
                                   HorizontalAlignment="Right"
                                   Cursor="Hand"
                                   Margin="0,10,0,14" >
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="TextDecorations" Value="Underline"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="MouseDown">
                                <i:InvokeCommandAction Command="{Binding QuenMatKhauCommand}"/>
                                </i:EventTrigger>
                           </i:Interaction.Triggers>
                        </TextBlock>
                    </StackPanel>

                </Grid>

            </Border>

        </Grid>
    </Border>

</Window>