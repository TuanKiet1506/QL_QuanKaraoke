<UserControl x:Class="QL_QuanKaraoke_BETA_1.View.QL_HoaDonUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QL_QuanKaraoke_BETA_1"
             mc:Ignorable="d" 
             d:DesignHeight="550" d:DesignWidth="950"
             Background="White"
             DataContext="{StaticResource QLHoaDonVM}">
    <UserControl.Resources>


    </UserControl.Resources>

    <Grid Margin="24,20,24,20">
        <Grid.RowDefinitions>
            <!-- Tiêu đề -->
            <RowDefinition Height="Auto"/>
            <!-- Gap -->
            <RowDefinition Height="20"/>
            <!-- Input: HoTen + SoDienThoai -->
            <RowDefinition Height="Auto"/>
            <!-- Gap -->
            <RowDefinition Height="14"/>
            <!-- Toolbar: Filter + Search -->
            <RowDefinition Height="Auto"/>
            <!-- Gap -->
            <RowDefinition Height="14"/>
            <!-- ListView -->
            <RowDefinition Height="*"/>
            <!-- Gap -->
            <RowDefinition Height="14"/>
            <!-- Buttons -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══════════ ROW 0 — Tiêu đề ══════════ -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="🧾" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"
                       Foreground="#F88888"/>
            <TextBlock Text="Quản Lý Hóa Đơn"
                       Foreground="#F88888"
                       FontSize="22"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- ══════════ ROW 2 — Input HoTen + SoDienThoai ══════════ -->
        <Border Grid.Row="2"
                Background="#F9F9F9"
                BorderThickness="1"
                BorderBrush="#DDDDDD"
                Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="160"/>
                </Grid.ColumnDefinitions>

                <!-- Họ tên -->
                <TextBlock Grid.Column="0"
                           Text="Khách Hàng"
                           Foreground="Black"
                           FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <Border Background="White"
                        Height="25"
                        Margin="0,0,0,0" 
                        Grid.Column="1"
                        BorderBrush="#CCCCCC"
                        BorderThickness="1"
                        >
                    <Grid>
                        <TextBox
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="Black"
                             FontSize="14"
                             VerticalContentAlignment="Center"
                             Padding="4,0,10,0"
                             IsReadOnly="True"
                             Text="{Binding SelectedHoaDon.KhachHang.HoTen}"
                     />
                    </Grid>
                </Border>

                <!-- Số điện thoại -->
                <TextBlock Grid.Column="3"
                           Text="Trạng thái"
                           Foreground="Black"
                           FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <Border Background="White"
                           Height="25"
                           Margin="0,0,0,0" 
                           Grid.Column="4"
                        BorderBrush="#CCCCCC"
                        BorderThickness="1"
                                           >
                    <Grid>
                        <TextBox
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="Black"
                                FontSize="14"
                                VerticalContentAlignment="Center"
                                Padding="4,0,10,0"
                                IsReadOnly="True"
                                Text="{Binding SelectedHoaDon.TrangThai}"
                                   />
                    </Grid>
                </Border>

                <!-- Chức vụ -->
                <TextBlock Grid.Column="6"
                           Text="Tổng tiền"
                           Foreground="Black"
                           FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <Border Background="White"
                        Height="25"
                        Margin="0,0,0,0" 
                        Grid.Column="7"
                        BorderBrush="#CCCCCC"
                        BorderThickness="1"
                            >
                    <Grid>
                        <TextBox
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="Black"
                         FontSize="14"
                         VerticalContentAlignment="Center"
                         Padding="4,0,10,0"
                         IsReadOnly="True"
                         Text="{Binding SelectedHoaDon.TongTien, StringFormat={}{0:N0} đ}"
                         />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ══════════ ROW 4 — Filter + Search ══════════ -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ComboBox lọc trạng thái -->
            <ComboBox Grid.Column="0"
                      Height="38"
                      ItemsSource="{Binding DSTrangThai, UpdateSourceTrigger=PropertyChanged}"
                      SelectedItem="{Binding TrangThaiDangChon, UpdateSourceTrigger=PropertyChanged}"
                      />

            <!-- TextBox tìm kiếm -->
            <Grid Grid.Column="2">
                <Border Background="White"
                Height="46"
                Margin="0"
                        BorderBrush="#CCCCCC"
                        BorderThickness="1">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Width="18"
                       Height="18"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Text="🔍"
                                   Foreground="Black"/>

                        <TextBox Grid.Column="1" Text="{Binding TuKhoa, UpdateSourceTrigger=PropertyChanged}"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="Black"
                         FontSize="14"
                         VerticalContentAlignment="Center"
                         Padding="4,0,10,0"
                         Width="638"/>
                    </Grid>

                </Border>
            </Grid>
        </Grid>

        <!-- ══════════ ROW 6 — ListView ══════════ -->
        <Border Grid.Row="6"
                ClipToBounds="True"
                BorderThickness="1.5"
                BorderBrush="#2E2B4A">
            <ListView BorderBrush="#CCCCCC"
                      BorderThickness="1"
                      FontSize="13"
                      FontFamily="Segoe UI"
                      ItemsSource="{Binding DanhSachHoaDonView, UpdateSourceTrigger=PropertyChanged}"
                      SelectedItem="{Binding SelectedHoaDon}">

                <ListView.View>
                    <GridView>

                        <!-- Mã NV -->
                        <GridViewColumn Header="Mã HD" Width="70">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding MaHoaDon}"
                                               Foreground="#9490B0"
                                               FontSize="12"
                                               Padding="14,10"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Tên đăng nhập -->
                        <GridViewColumn Header="Mã Phòng" Width="80">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding MaPhong}"
                                               Foreground="#7C5CFC"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Padding="14,10"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Họ tên -->
                        <GridViewColumn Header="Khách hàng" Width="88">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding MaKhachHang}"
                                               Foreground="Black"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Padding="14,10"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Số điện thoại -->
                        <GridViewColumn Header="Mã nhân viên" Width="96">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding MaNhanVien}"
                                               Foreground="Black"
                                               FontSize="12"
                                               Padding="14,10"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Chức vụ -->
                        <GridViewColumn Header="Giờ vào" Width="170">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding GioVao}"
                                                   Foreground="Black"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        
                        <GridViewColumn Header="Giờ ra" Width="170">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                        <TextBlock Text="{Binding GioRa}"
                                                   Foreground="Black"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        
                        <GridViewColumn Header="Tổng tiền" Width="110">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding TongTien, StringFormat={}{0:N0} đ}"
                                                   Foreground="#7C5CFC"
                                                   FontSize="12"
                                                   FontWeight="Bold"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Trạng thái -->
                        <GridViewColumn Header="Trạng Thái" Width="180">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding TrangThai}"
                                               Foreground="Black"
                                               FontSize="11"
                                               Name="TrangThaiText"
                                               FontWeight="Bold"/>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding TrangThai}" Value="DANG_MO">
                                            <Setter TargetName="TrangThaiText" Property="Text" Value="Đang Mở"/>
                                            <Setter TargetName="TrangThaiText" Property="Foreground" Value="#7C5CFC"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding TrangThai}" Value="DA_THANH_TOAN">
                                            <Setter TargetName="TrangThaiText" Property="Text" Value="Đã Thanh Toán"/>
                                            <Setter TargetName="TrangThaiText" Property="Foreground" Value="#16A34A"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding TrangThai}" Value="CHUA_THANH_TOAN">
                                            <Setter TargetName="TrangThaiText" Property="Text" Value="Chưa thanh toán"/>
                                            <Setter TargetName="TrangThaiText" Property="Foreground" Value="#DC2626"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>

                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>

            </ListView>
        </Border>

        <!-- ══════════ ROW 8 — Buttons ══════════ -->
        <Grid Grid.Row="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
            </Grid.ColumnDefinitions>


            <!-- Sửa -->
            <Button Grid.Column="2"
                    Content="✏  Cập nhật trạng thái"
                    Height="40"
                    Command="{Binding CapNhatCommand}"
                    >
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1D4ED8" Offset="0"/>
                        <GradientStop Color="#38BDF8" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>

            </Button>

            <!-- Khóa tài khoản -->
            <Button Grid.Column="4"
                    Height="40"
                    Command="{Binding HuyCommand}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔒  " VerticalAlignment="Center"/>
                    <TextBlock Text="Hủy hóa đơn" VerticalAlignment="Center"/>
                </StackPanel>

                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#DC2626" Offset="0"/>
                        <GradientStop Color="#F87171" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>

            </Button>


        </Grid>

    </Grid>
</UserControl>
