<UserControl x:Class="QL_QuanKaraoke_BETA_1.View.QL_HoaDonUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QL_QuanKaraoke_BETA_1"
             mc:Ignorable="d" 
             d:DesignHeight="550" d:DesignWidth="950"
             DataContext="{StaticResource QLHoaDonVM}">
    <UserControl.Resources>

        <!-- ══════════════════════════════════════
             LISTVIEW — COLUMN HEADER
        ══════════════════════════════════════ -->
        <Style x:Key="HeaderStyle" TargetType="GridViewColumnHeader">
            <Setter Property="Background"           Value="#22203A"/>
            <Setter Property="Foreground"           Value="#9490B0"/>
            <Setter Property="FontSize"             Value="11"/>
            <Setter Property="FontWeight"           Value="SemiBold"/>
            <Setter Property="Padding"              Value="14,10"/>
            <Setter Property="BorderThickness"      Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══════════════════════════════════════
             LISTVIEW — ROW (ListViewItem)
        ══════════════════════════════════════ -->
        <Style x:Key="NvRowStyle" TargetType="ListViewItem">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#F0EEF8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="RowBorder"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0,0,0,1"
                                BorderBrush="#1E1C31"
                                Padding="0,2">
                            <GridViewRowPresenter
                                Columns="{Binding Path=View.Columns,
                                          RelativeSource={RelativeSource AncestorType=ListView}}"
                                Content="{TemplateBinding Content}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RowBorder" Property="Background" Value="#22203A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="RowBorder" Property="Background" Value="#2A2740"/>
                                <Setter TargetName="RowBorder" Property="BorderBrush" Value="#7C5CFC"/>
                                <Setter TargetName="RowBorder" Property="BorderThickness" Value="0,0,0,1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══════════════════════════════════════
             LISTVIEW CHÍNH
        ══════════════════════════════════════ -->
        <Style x:Key="NvListView" TargetType="ListView">
            <Setter Property="Background"       Value="#1A1829"/>
            <Setter Property="BorderThickness"  Value="1.5"/>
            <Setter Property="BorderBrush"      Value="#2E2B4A"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility"   Value="Auto"/>
        </Style>

        <!-- ══════════════════════════════════════
             BADGE: TRẠNG THÁI
             TrangThai = 1  → Đang làm việc (xanh)
             TrangThai = 0  → Nghỉ việc / Bị khóa (xem ChucVu/flag)
             → Dùng DataTrigger trực tiếp trong CellTemplate
        ══════════════════════════════════════ -->

    </UserControl.Resources>

    <Grid Margin="24,20,24,20">
        <Grid.RowDefinitions>
            <!-- Tiêu đề -->
            <RowDefinition Height="Auto"/>
            <!-- Gap -->
            <RowDefinition Height="20"/>
            <!-- Input: HoTen + SoDienThoai -->
            <RowDefinition Height="Auto"/>
            <!-- Gap -->
            <RowDefinition Height="14"/>
            <!-- Toolbar: Filter + Search -->
            <RowDefinition Height="Auto"/>
            <!-- Gap -->
            <RowDefinition Height="14"/>
            <!-- ListView -->
            <RowDefinition Height="*"/>
            <!-- Gap -->
            <RowDefinition Height="14"/>
            <!-- Buttons -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══════════ ROW 0 — Tiêu đề ══════════ -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="🧾" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBlock Text="Quản Lý Hóa Đơn"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- ══════════ ROW 2 — Input HoTen + SoDienThoai ══════════ -->
        <Border Grid.Row="2"
                Background="#1E1C31"
                CornerRadius="14"
                BorderThickness="1.5"
                BorderBrush="#2E2B4A"
                Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="160"/>
                </Grid.ColumnDefinitions>

                <!-- Họ tên -->
                <TextBlock Grid.Column="0"
                           Text="Khách Hàng"
                           Foreground="#9490B0"
                           FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <Border Background="#353340"
                        CornerRadius="8"
                        Height="25"
                        Margin="0,0,0,0" 
                        Grid.Column="1"
                        >
                    <Grid>
                        <TextBox
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#E6E6E6"
                             FontSize="14"
                             VerticalContentAlignment="Center"
                             Padding="4,0,10,0"
                             Style="{StaticResource TextBoxTheme}"
                             IsReadOnly="True"
                             Text="{Binding SelectedHoaDon.KhachHang.HoTen}"
                     />
                    </Grid>
                </Border>

                <!-- Số điện thoại -->
                <TextBlock Grid.Column="3"
                           Text="Trạng thái"
                           Foreground="#9490B0"
                           FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <Border Background="#353340"
                           CornerRadius="8"
                           Height="25"
                           Margin="0,0,0,0" 
                           Grid.Column="4"
                                           >
                    <Grid>
                        <TextBox
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="#E6E6E6"
                                FontSize="14"
                                VerticalContentAlignment="Center"
                                Padding="4,0,10,0"
                                Style="{StaticResource TextBoxTheme}"
                                IsReadOnly="True"
                                Text="{Binding SelectedHoaDon.TrangThai}"
                                   />
                    </Grid>
                </Border>

                <!-- Chức vụ -->
                <TextBlock Grid.Column="6"
                           Text="Tổng tiền"
                           Foreground="#9490B0"
                           FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <Border Background="#353340"
                        CornerRadius="8"
                        Height="25"
                        Margin="0,0,0,0" 
                        Grid.Column="7"
                            >
                    <Grid>
                        <TextBox
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="#E6E6E6"
                         FontSize="14"
                         VerticalContentAlignment="Center"
                         Padding="4,0,10,0"
                         Style="{StaticResource TextBoxTheme}"
                         IsReadOnly="True"
                         Text="{Binding SelectedHoaDon.TongTien, StringFormat={}{0:N0} đ}"
                         />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ══════════ ROW 4 — Filter + Search ══════════ -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ComboBox lọc trạng thái -->
            <ComboBox Grid.Column="0"
                      Height="38"
                      Style="{StaticResource ModernComboBox}"
                      ItemsSource="{Binding DSTrangThai, UpdateSourceTrigger=PropertyChanged}"
                      SelectedItem="{Binding TrangThaiDangChon, UpdateSourceTrigger=PropertyChanged}"
                      />

            <!-- TextBox tìm kiếm -->
            <Grid Grid.Column="2">
                <Border Background="#2A2740"
                CornerRadius="8"
                Height="46"
                Margin="0">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Width="18"
                       Height="18"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Text="🔍"/>

                        <TextBox Grid.Column="1" Text="{Binding TuKhoa, UpdateSourceTrigger=PropertyChanged}"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="#E6E6E6"
                         FontSize="14"
                         VerticalContentAlignment="Center"
                         Padding="4,0,10,0"
                         Style="{StaticResource TextBoxTheme}"
                         Tag="Tìm kiếm"
                         Width="638"/>
                    </Grid>

                </Border>
            </Grid>
        </Grid>

        <!-- ══════════ ROW 6 — ListView ══════════ -->
        <Border Grid.Row="6"
                CornerRadius="14"
                ClipToBounds="True"
                BorderThickness="1.5"
                BorderBrush="#2E2B4A">
            <ListView Style="{StaticResource NvListView}"
                      ItemContainerStyle="{StaticResource NvRowStyle}"
                      ItemsSource="{Binding DanhSachHoaDonView, UpdateSourceTrigger=PropertyChanged}"
                      SelectedItem="{Binding SelectedHoaDon}">

                <ListView.View>
                    <GridView ColumnHeaderContainerStyle="{StaticResource HeaderStyle}">

                        <!-- Mã NV -->
                        <GridViewColumn Header="Mã HD" Width="70">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding MaHoaDon}"
                                               Foreground="#9490B0"
                                               FontSize="12"
                                               Padding="14,10"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Tên đăng nhập -->
                        <GridViewColumn Header="Mã Phòng" Width="80">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding MaPhong}"
                                               Foreground="#7C5CFC"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Padding="14,10"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Họ tên -->
                        <GridViewColumn Header="Khách hàng" Width="88">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding MaKhachHang}"
                                               Foreground="#F0EEF8"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Padding="14,10"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Số điện thoại -->
                        <GridViewColumn Header="Mã nhân viên" Width="96">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding MaNhanVien}"
                                               Foreground="#C8C4E0"
                                               FontSize="12"
                                               Padding="14,10"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Chức vụ -->
                        <GridViewColumn Header="Giờ vào" Width="170">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8" Padding="8,3"
                                            Margin="14,8"
                                            Background="#22203A"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding GioVao}"
                                                   Foreground="#9490B0"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        
                        <GridViewColumn Header="Giờ ra" Width="170">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8" Padding="8,3"
                                            Margin="14,8"
                                            Background="#22203A"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding GioRa}"
                                                   Foreground="#9490B0"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        
                        <GridViewColumn Header="Tổng tiền" Width="110">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8" Padding="8,3"
                                            Margin="14,8"
                                            Background="#22203A"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding TongTien, StringFormat={}{0:N0} đ}"
                                                   Foreground="#9490B0"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Trạng thái -->
                        <GridViewColumn Header="Trạng thái" Width="160">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <!-- Mặc định: DANG_MO (tím) -->
                                    <Border x:Name="BadgeBorder"
                    CornerRadius="20"
                    Padding="10,4"
                    Margin="14,8"
                    HorizontalAlignment="Left"
                    Background="#2A1F4A">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse x:Name="BadgeDot"
                             Width="7" Height="7"
                             Fill="#7C5CFC"
                             VerticalAlignment="Center"
                             Margin="0,0,6,0"/>
                                            <TextBlock x:Name="BadgeText"
                               Text="🔓 Đang mở"
                               Foreground="#7C5CFC"
                               FontSize="11"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>

                                    <DataTemplate.Triggers>
                                        <!-- "DA_THANH_TOAN" → Xanh lá -->
                                        <DataTrigger Binding="{Binding TrangThai}" Value="DA_THANH_TOAN">
                                            <Setter TargetName="BadgeBorder" Property="Background" Value="#1A3A28"/>
                                            <Setter TargetName="BadgeDot"    Property="Fill"       Value="#4ADE80"/>
                                            <Setter TargetName="BadgeText"   Property="Text"       Value="✔ Đã thanh toán"/>
                                            <Setter TargetName="BadgeText"   Property="Foreground" Value="#4ADE80"/>
                                        </DataTrigger>
                                        <!-- "CHUA_THANH_TOAN" → Đỏ -->
                                        <DataTrigger Binding="{Binding TrangThai}" Value="CHUA_THANH_TOAN">
                                            <Setter TargetName="BadgeBorder" Property="Background" Value="#3A1A1A"/>
                                            <Setter TargetName="BadgeDot"    Property="Fill"       Value="#F87171"/>
                                            <Setter TargetName="BadgeText"   Property="Text"       Value="✖ Chưa thanh toán"/>
                                            <Setter TargetName="BadgeText"   Property="Foreground" Value="#F87171"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>

            </ListView>
        </Border>

        <!-- ══════════ ROW 8 — Buttons ══════════ -->
        <Grid Grid.Row="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
            </Grid.ColumnDefinitions>


            <!-- Sửa -->
            <Button Grid.Column="2"
                    Content="✏  Cập nhật trạng thái"
                    Height="40"
                    Command="{Binding CapNhatCommand}"
                    >
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1D4ED8" Offset="0"/>
                        <GradientStop Color="#38BDF8" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>

            </Button>

            <!-- Khóa tài khoản -->
            <Button Grid.Column="4"
                    Height="40"
                    Command="{Binding HuyCommand}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔒  " VerticalAlignment="Center"/>
                    <TextBlock Text="Hủy hóa đơn" VerticalAlignment="Center"/>
                </StackPanel>

                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#DC2626" Offset="0"/>
                        <GradientStop Color="#F87171" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>

            </Button>


        </Grid>

    </Grid>
</UserControl>
