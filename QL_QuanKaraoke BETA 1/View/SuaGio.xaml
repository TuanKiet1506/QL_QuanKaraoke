<Window x:Class="QL_QuanKaraoke_BETA_1.View.SuaGio"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QL_QuanKaraoke_BETA_1"
        mc:Ignorable="d"
        Title="SuaGio" DataContext="{StaticResource SuaGioVM}"
        Height="600" Width="560"
        WindowStartupLocation="CenterScreen"
        Background="White"
        ResizeMode="NoResize"
        Name="SuaGioWD">
    <Grid Margin="32,28,32,28">
        <Grid.RowDefinitions>
            <!-- Tiêu đề -->
            <RowDefinition Height="Auto"/>
            <!-- Gap -->
            <RowDefinition Height="24"/>
            <!-- Phòng hiện tại -->
            <RowDefinition Height="Auto"/>
            <!-- Gap -->
            <RowDefinition Height="20"/>
            <!-- Mũi tên chuyển -->
            <RowDefinition Height="Auto"/>
            <!-- Gap -->
            <RowDefinition Height="20"/>
            <!-- Phòng mới -->
            <RowDefinition Height="Auto"/>
            <!-- Gap -->
            <RowDefinition Height="28"/>
            <!-- Nút Xác nhận -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══════════ ROW 0 — Tiêu đề ══════════ -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
            <Border Background="#F88888"
                    Padding="10,8" Margin="0,0,12,0">
                <TextBlock Text="🕒" FontSize="18" Foreground="Black"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Sửa Giờ Phục Vụ"
                           Foreground="#F88888"
                           FontSize="20"
                           FontWeight="Bold"/>
                <TextBlock Text="Thay đổi giờ quán mở/đóng cửa"
                           Foreground="Black"
                           FontSize="11"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </StackPanel>

        <!-- ══════════ ROW 2 — Card: Phòng Hiện Tại ══════════ -->
        <Border Grid.Row="2"
                Background="#FFF3F3"
                BorderThickness="1.5"
                BorderBrush="#F88888"
                Padding="20,16">
            <StackPanel>

                <!-- Nhãn section -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                    <TextBlock Text="Khung giờ hiện tại"
                               Foreground="Red"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 3 ô thông tin -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Tên phòng -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Giờ Vào"
                                   Foreground="Black"
                                   FontSize="11"
                                   Margin="0,0,0,6"/>
                        <Border Background="White"
                                Height="25"
                                Margin="0,0,0,14"
                                BorderBrush="#CCCCCC"
                                BorderThickness="1">
                            <Grid>
                                <TextBox
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="Black"
                                         FontSize="14"
                                         VerticalContentAlignment="Center"
                                         Padding="4,0,10,0"
                                         IsReadOnly="True"
                                         Text="{Binding GioVaoCu}"/>
                            </Grid>
                        </Border>

                    </StackPanel>

                    <!-- Sức chứa -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Giờ Ra"
                                   Foreground="Black"
                                   FontSize="11"
                                   Margin="0,0,0,6"/>
                        <Border Background="White"
                                Height="25"
                                Margin="0,0,0,14"
                                BorderBrush="#CCCCCC"
                                BorderThickness="1">
                            <Grid>
                                <TextBox
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="Black"
                                         FontSize="14"
                                         VerticalContentAlignment="Center"
                                         Padding="4,0,10,0"
                                         IsReadOnly="True"
                                         Text="{Binding GioRaCu}"/>
                            </Grid>
                        </Border>

                    </StackPanel>


                </Grid>
            </StackPanel>
        </Border>

        <!-- ══════════ ROW 4 — Mũi tên ══════════ -->
        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Center">
            <Border Background="#FFF3F3" CornerRadius="20"
                    Padding="18,8" BorderBrush="Red" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⬇" FontSize="14"
                               Foreground="#7C5CFC"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <TextBlock Text="Đổi sang khung giờ"
                               Foreground="Black"
                               FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- ══════════ ROW 6 — Card: Phòng Mới ══════════ -->
        <Border Grid.Row="6"
                Background="#FFF3F3"
                BorderThickness="1.5"
                BorderBrush="#F88888"
                Padding="20,16">
            <StackPanel>

                <!-- Nhãn section -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                    <TextBlock Text="Khung giờ thay đổi"
                               Foreground="DarkGreen"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 3 ô thông tin phòng mới (readonly, tự điền khi chọn combobox) -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Tên phòng -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Giờ Vào"
                                   Foreground="Black"
                                   FontSize="11"
                                   Margin="0,0,0,6"/>
                        <Border Background="White"
                                Height="25"
                                Margin="0,0,0,14">
                            <Grid>
                                <ComboBox
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="#E6E6E6"
                                         FontSize="14"
                                         VerticalContentAlignment="Center"
                                         Padding="4,0,10,0"
                                         ItemsSource="{Binding DanhSachGio}"
                                         SelectedItem="{Binding GioVaoMoi}"
                                         />
                            </Grid>
                        </Border>

                    </StackPanel>

                    <!-- Sức chứa -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Giờ Ra"
                                   Foreground="Black"
                                   FontSize="11"
                                   Margin="0,0,0,6"/>
                        <Border Background="White"
                                Height="25"
                                Margin="0,0,0,14">
                            <Grid>
                                
                                <ComboBox
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="#E6E6E6"
                                         FontSize="14"
                                         VerticalContentAlignment="Center"
                                         Padding="4,0,10,0"
                                         ItemsSource="{Binding DanhSachGio}"
                                         SelectedItem="{Binding GioRaMoi}"
                                         />
                            </Grid>
                        </Border>

                    </StackPanel>

                </Grid>
            </StackPanel>
        </Border>

        <!-- ══════════ ROW 8 — Nút Xác Nhận ══════════ -->
        <Button Height="46"
                                Cursor="Hand"
                                BorderThickness="0"
                                Grid.Row="8"
                                Command="{Binding XacNhanSuaGioCommand}"
                                CommandParameter="{Binding ElementName=SuaGioWD}">

            <Button.Template>
                <ControlTemplate TargetType="Button">

                    <Border x:Name="LoginBorder"
                                            CornerRadius="8"
                                            Height="46">

                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FFE01A38" Offset="0"/>
                                <GradientStop Color="#FFD81D1D" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>

                        <TextBlock Text="✔  Xác Nhận Chuyển Giờ"
                                                   Foreground="White"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   FontFamily="Segoe UI"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>

                    </Border>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="LoginBorder"
                                                    Property="Opacity"
                                                    Value="0.88"/>
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="LoginBorder"
                                                    Property="Opacity"
                                                    Value="0.72"/>
                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Button.Template>

        </Button>

    </Grid>

</Window>
