<Window x:Class="QL_QuanKaraoke_BETA_1.View.ThanhToanWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QL_QuanKaraoke_BETA_1"
        mc:Ignorable="d"
        Title="ThanhToanWindow"
        Height="810" Width="500"
        WindowStartupLocation="CenterScreen"
        Background="#13111F"
        ResizeMode="NoResize"
        DataContext="{StaticResource ThanhToanVM}"
        Name="ThanhToanWD">
    <Grid Margin="32,28,32,28">
        <Grid.RowDefinitions>
            <!-- Tiêu đề -->
            <RowDefinition Height="Auto"/>
            <!-- Gap -->
            <RowDefinition Height="20"/>
            <!-- Card: Thông tin phòng -->
            <RowDefinition Height="Auto"/>
            <!-- Gap -->
            <RowDefinition Height="14"/>
            <!-- Card: Dịch vụ -->
            <RowDefinition Height="Auto"/>
            <!-- Gap -->
            <RowDefinition Height="14"/>
            <!-- Card: Thành viên -->
            <RowDefinition Height="Auto"/>
            <!-- Gap -->
            <RowDefinition Height="14"/>
            <!-- Card: Tổng tiền -->
            <RowDefinition Height="Auto"/>
            <!-- Gap -->
            <RowDefinition Height="24"/>
            <!-- Buttons -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══════════ ROW 0 — Tiêu đề ══════════ -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
            <Border Background="#2A2740" CornerRadius="10"
                    Padding="10,8" Margin="0,0,12,0">
                <TextBlock Text="💳" FontSize="18"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Thanh Toán"
                           Foreground="#F0EEF8"
                           FontSize="20"
                           FontWeight="Bold"/>
                <TextBlock Text="Xác nhận và hoàn tất thanh toán cho khách"
                           Foreground="#9490B0"
                           FontSize="11"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </StackPanel>

        <!-- ══════════ ROW 2 — Card: Tiền phòng ══════════ -->
        <Border Grid.Row="2"
                Background="#1E1C31"
                CornerRadius="14"
                BorderThickness="1.5"
                BorderBrush="#2E2B4A"
                Padding="18,14">
            <StackPanel>

                <!-- Nhãn section -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <Border Width="4" Height="15" CornerRadius="2"
                            Background="#7C5CFC" Margin="0,0,8,0"
                            VerticalAlignment="Center"/>
                    <TextBlock Text="Thông Tin Phòng"
                               Foreground="#7C5CFC"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Tên phòng (có thể là nhiều phòng nếu chuyển phòng) -->
                <StackPanel Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="Tiền phòng"
                                   Foreground="#9490B0"
                                   FontSize="11"
                                   VerticalAlignment="Center"/>
                        <!-- Badge: số phòng đã dùng (binding động) -->
                        <Border Background="#22203A" CornerRadius="8"
                                Padding="8,2" Margin="8,0,0,0"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🏠 "
                                           FontSize="10"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding DanhSachPhong.Count}"
                                           Foreground="#9490B0"
                                           FontSize="10"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <Border Background="#353340"
                                CornerRadius="8"
                                Height="25"
                                Margin="0,0,0,14">
                        <Grid>
                            <TextBox
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="#E6E6E6"
                                         FontSize="14"
                                         VerticalContentAlignment="Center"
                                         Padding="4,0,10,0"
                                         Style="{StaticResource TextBoxTheme}"
                                         IsReadOnly="True"
                                         Text="{Binding TienPhong, StringFormat={}{0:N0}đ}"/>
                        </Grid>
                    </Border>

                </StackPanel>

            </StackPanel>
        </Border>

        <!-- ══════════ ROW 4 — Card: Tiền dịch vụ ══════════ -->
        <Border Grid.Row="4"
                Background="#1E1C31"
                CornerRadius="14"
                BorderThickness="1.5"
                BorderBrush="#2E2B4A"
                Padding="18,14">
            <StackPanel>

                <!-- Nhãn section -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <Border Width="4" Height="15" CornerRadius="2"
                            Background="#38BDF8" Margin="0,0,8,0"
                            VerticalAlignment="Center"/>
                    <TextBlock Text="Dịch Vụ"
                               Foreground="#38BDF8"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Tiền dịch vụ"
                               Foreground="#9490B0"
                               FontSize="11"
                               Margin="0,0,0,6"/>
                    <Border Background="#353340"
                                CornerRadius="8"
                                Height="25"
                                Margin="0,0,0,14">
                        <Grid>
                            <TextBox
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="#E6E6E6"
                                         FontSize="14"
                                         VerticalContentAlignment="Center"
                                         Padding="4,0,10,0"
                                         Style="{StaticResource TextBoxTheme}"
                                         IsReadOnly="True"
                                         Text="{Binding TienDichVu, StringFormat={}{0:N0}đ}"/>
                        </Grid>
                    </Border>

                </StackPanel>

            </StackPanel>
        </Border>

        <!-- ══════════ ROW 6 — Card: Thành viên & Giảm giá ══════════ -->
        <Border Grid.Row="6"
                Background="#1E1C31"
                CornerRadius="14"
                BorderThickness="1.5"
                BorderBrush="#2E2B4A"
                Padding="18,14">
            <StackPanel>

                <!-- Nhãn section -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <Border Width="4" Height="15" CornerRadius="2"
                            Background="#FBBF24" Margin="0,0,8,0"
                            VerticalAlignment="Center"/>
                    <TextBlock Text="Ưu Đãi Thành Viên"
                               Foreground="#FBBF24"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>

                    <!-- Hạng thành viên -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Hạng thành viên"
                                   Foreground="#9490B0"
                                   FontSize="11"
                                   Margin="0,0,0,6"/>
                        <Border Background="#353340"
                                CornerRadius="8"
                                Height="25"
                                Margin="0,0,0,14">
                            <Grid>
                                <TextBox
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="#E6E6E6"
                                         FontSize="14"
                                         VerticalContentAlignment="Center"
                                         Padding="4,0,10,0"
                                         Style="{StaticResource TextBoxTheme}"
                                         IsReadOnly="True"
                                         Text="{Binding HangThanhVien}"/>
                            </Grid>
                        </Border>

                    </StackPanel>

                    <!-- Phần trăm giảm -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Giảm giá"
                                   Foreground="#9490B0"
                                   FontSize="11"
                                   Margin="0,0,0,6"/>
                        <Border Background="#353340"
                                CornerRadius="8"
                                Height="25"
                                Margin="0,0,0,14">
                            <Grid>
                                <TextBox
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="#E6E6E6"
                                         FontSize="14"
                                         VerticalContentAlignment="Center"
                                         Padding="4,0,10,0"
                                         Style="{StaticResource TextBoxTheme}"
                                         IsReadOnly="True"
                                         Text="{Binding PhanTramGiamGia, StringFormat={}{0}%}"/>
                            </Grid>
                        </Border>

                    </StackPanel>
                </Grid>

            </StackPanel>
        </Border>

        <!-- ══════════ ROW 8 — Card: Tổng tiền ══════════ -->
        <Border Grid.Row="8"
                Background="#22203A"
                CornerRadius="14"
                BorderThickness="1.5"
                BorderBrush="#3D3860"
                Padding="18,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Tổng thanh toán"
                               Foreground="#9490B0"
                               FontSize="12"
                               FontWeight="SemiBold"/>
                    <TextBlock Foreground="#9490B0"
                               FontSize="11"
                               Margin="0,3,0,0">
                        <Run Text="(Sau giảm "/>
                        <Run Text="{Binding PhanTramGiamGia, StringFormat={}{0}%}"
                             Foreground="#FBBF24"
                             FontWeight="SemiBold"/>
                        <Run Text=")"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <TextBlock Text="{Binding TongTien, StringFormat={}{0:N0} đ}"
                               Foreground="#F0EEF8"
                               FontSize="24"
                               FontWeight="Bold"
                               HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════ ROW 10 — Buttons ══════════ -->
        <StackPanel Grid.Row="10">

            <!-- Xác nhận thanh toán -->
            <Button Content="✔  Xác Nhận Thanh Toán"
                    Style="{StaticResource ModernButton}"
                    Height="44"
                    Command="{Binding XacNhanThanhToanCommand}"
                    CommandParameter="{Binding ElementName=ThanhToanWD}"
                    >
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#7C5CFC" Offset="0"/>
                        <GradientStop Color="#C084FC" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>
            </Button>

            <!-- Divider chữ "hoặc" -->
            <Grid Margin="0,12,0,12">
                <Border Height="1" Background="#2E2B4A"
                        VerticalAlignment="Center"/>
                <Border Background="#13111F"
                        Padding="10,0"
                        HorizontalAlignment="Center">
                    <TextBlock Text="hoặc"
                               Foreground="#9490B0"
                               FontSize="11"/>
                </Border>
            </Grid>

            <!-- Trả phòng & thanh toán sau -->
            <Button Height="44"
                    Command="{Binding TraPhongThanhToanSauCommand}"
                    CommandParameter="{Binding ElementName=ThanhToanWD}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource ModernButton}">
                    </Style>
                </Button.Style>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🕐  " FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Text="Trả Phòng &amp; Thanh Toán Sau"
                               FontSize="13"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#2A2740" Offset="0"/>
                        <GradientStop Color="#1E3A50" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>
            </Button>

        </StackPanel>

    </Grid>

</Window>
