<Window x:Class="QL_QuanKaraoke_BETA_1.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QL_QuanKaraoke_BETA_1"
        mc:Ignorable="d"
        Title="MainWindow" Height="850" Width="1280" DataContext="{StaticResource MainVM}"
        Background="#272537" WindowStyle="None" ResizeMode="CanResize" AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown" Name="MainWD" WindowStartupLocation="CenterScreen">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadedWindowCommand}" CommandParameter="{Binding ElementName=MainWD}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Border Background="#272537" CornerRadius="20">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="75"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <!-- Top Control Bar -->
            <StackPanel Grid.Row="0"
                Grid.Column="1"
                Style="{StaticResource ControlBarPanelStyle}">
                <Button Style="{StaticResource MinimizeButtonStyle}"
                Command="{Binding MinimizeCommand}"
                CommandParameter="{Binding ElementName=MainWD}"/>

                <Button Style="{StaticResource MaximizeButtonStyle}"
                Command="{Binding MaximizeCommand}"
                CommandParameter="{Binding ElementName=MainWD}"/>

                <Button Style="{StaticResource CloseButtonStyle}"
                Command="{Binding ExitCommand}"
                CommandParameter="{Binding ElementName=MainWD}"/>
            </StackPanel>

            <!-- Title -->
            <TextBlock Grid.Row="0"
               Grid.Column="0"
               Text="Quán Karaoke"
               Foreground="White"
               FontSize="22"
               VerticalAlignment="Center"
               Margin="20,0,0,0"/>

            <!-- Sidebar -->
            <Grid Grid.Row="1" Grid.Column="0">

                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- MENU -->
                <ScrollViewer>
                <StackPanel Grid.Row="0">
                    <RadioButton Foreground="White"
                         Style="{StaticResource MenuButtonTheme}"
                         Content="Trang Chủ"
                         Command="{Binding TrangChuCommand}"
                         Height="50"
                         IsChecked="True"/>

                    <RadioButton Foreground="White"
                         Style="{StaticResource MenuButtonTheme}"
                         Content="Đặt Phòng"
                         Command="{Binding DatPhongCommand}"
                         Height="50"/>
                    
                    
                    <RadioButton Foreground="White"
                         Style="{StaticResource MenuButtonTheme}"
                         Content="Khách Hàng"
                         Command="{Binding QLKhachHangCommand}"
                         Height="50"/>

                    <RadioButton Foreground="White"
                                 Style="{StaticResource MenuButtonTheme}"
                                 Content="Hóa Đơn"
                                 Command="{Binding QLHoaDonCommand}"
                                 Height="50"/>

                    <!-- ADMIN MENU -->
                    <RadioButton Foreground="White"
                         Content="Quản lý nhân viên"
                         Height="50"
                         Command="{Binding QLNhanVienCommand}">

                        <RadioButton.Style>
                            <Style TargetType="RadioButton"
                           BasedOn="{StaticResource MenuButtonTheme}">

                                <Setter Property="Visibility" Value="Collapsed"/>

                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsAdmin, ElementName=MainWD}"
                                         Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>

                            </Style>
                        </RadioButton.Style>

                    </RadioButton>
                    <RadioButton Foreground="White"
                         Content="Dịch Vụ"
                         Height="50"
                         Command="{Binding QLDichVuCommand}">

                        <RadioButton.Style>
                            <Style TargetType="RadioButton"
                           BasedOn="{StaticResource MenuButtonTheme}">

                                <Setter Property="Visibility" Value="Collapsed"/>

                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsAdmin, ElementName=MainWD}"
                                         Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>

                            </Style>
                        </RadioButton.Style>

                    </RadioButton>

                    <RadioButton Foreground="White"
                         Content="Hạng Thành Viên"
                         Height="50"
                         Command="{Binding QLHangThanhVienCommand}">

                        <RadioButton.Style>
                            <Style TargetType="RadioButton"
                           BasedOn="{StaticResource MenuButtonTheme}">

                                <Setter Property="Visibility" Value="Collapsed"/>

                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsAdmin, ElementName=MainWD}"
                                         Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>

                            </Style>
                        </RadioButton.Style>

                    </RadioButton>
                    <RadioButton Foreground="White"
                         Content="Quản lý phòng"
                         Height="50"
                         Command="{Binding QLPhongCommand}">

                        <RadioButton.Style>
                            <Style TargetType="RadioButton"
                           BasedOn="{StaticResource MenuButtonTheme}">

                                <Setter Property="Visibility" Value="Collapsed"/>

                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsAdmin, ElementName=MainWD}"
                                         Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>

                            </Style>
                        </RadioButton.Style>

                    </RadioButton>

                    <RadioButton Foreground="White"
                         Content="Bảng Giá"
                         Height="50"
                         Command="{Binding QLBangGiaCommand}">

                        <RadioButton.Style>
                            <Style TargetType="RadioButton"
                           BasedOn="{StaticResource MenuButtonTheme}">

                                <Setter Property="Visibility" Value="Collapsed"/>

                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsAdmin, ElementName=MainWD}"
                                         Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>

                            </Style>
                        </RadioButton.Style>

                    </RadioButton>
                    <RadioButton Foreground="White"
                         Content="Lịch sử đăng nhập"
                         Height="50"
                         Command="{Binding QLDangNhapCommand}">

                        <RadioButton.Style>
                            <Style TargetType="RadioButton"
                           BasedOn="{StaticResource MenuButtonTheme}">

                                <Setter Property="Visibility" Value="Collapsed"/>

                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsAdmin, ElementName=MainWD}"
                                         Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>

                            </Style>
                        </RadioButton.Style>

                    </RadioButton>
                    <RadioButton Foreground="White"
                         Content="Hệ Thống"
                         Height="50"
                         Command="{Binding QLHeThongCommand}">

                        <RadioButton.Style>
                            <Style TargetType="RadioButton"
                           BasedOn="{StaticResource MenuButtonTheme}">

                                <Setter Property="Visibility" Value="Collapsed"/>

                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsAdmin, ElementName=MainWD}"
                                         Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>

                            </Style>
                        </RadioButton.Style>

                    </RadioButton>

                        
                </StackPanel>

                </ScrollViewer>

                <!-- LOGOUT BUTTON -->
                <Button Grid.Row="1"
                Content="Đăng Xuất"
                Height="45"
                Margin="10" Style="{StaticResource ModernButton}"
                Command="{Binding LogoutCommand}" CommandParameter="{Binding ElementName=MainWD}"
                />

            </Grid>

            <ContentControl Grid.Row="1" Grid.Column="1" Content="{Binding CurrentView}">
                
            </ContentControl>
        </Grid>
    </Border>
</Window>
