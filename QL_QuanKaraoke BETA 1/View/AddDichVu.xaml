<Window x:Class="QL_QuanKaraoke_BETA_1.View.AddDichVu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QL_QuanKaraoke_BETA_1"
        mc:Ignorable="d"
        Title="AddDichVu"
        Height="780" Width="600"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        DataContext="{StaticResource AddDichVuVM}"
        Name="AddDVWD">

    <!-- Outer border: white card with subtle shadow effect -->
    <Border CornerRadius="12"
            Background="White"
            BorderBrush="#E0E0E0"
            BorderThickness="1">

        <Grid>

            <StackPanel Margin="0,4,0,0">

                <!-- HEADER -->
                <Grid Margin="24,18,24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Icon + Title -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="34" Height="34"
                                Background="#E05555"
                                Margin="0,0,12,0">
                            <TextBlock Text="🍽️"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       FontSize="18"/>
                        </Border>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="THÊM DỊCH VỤ MỚI"
                                       Foreground="#C0392B"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       FontFamily="Segoe UI"/>
                            <TextBlock Text="Xác nhận thông tin dịch vụ"
                                       Foreground="#999999"
                                       FontSize="11"
                                       FontFamily="Segoe UI"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Close button -->
                    <Button Grid.Column="1"
                            Style="{StaticResource CloseButtonStyle}"
                            Command="{Binding ExitCommand}"
                            CommandParameter="{Binding ElementName=AddDVWD}"
                            VerticalAlignment="Top"/>
                </Grid>

                <!-- DIVIDER -->
                <Border Height="1"
                        Background="#EBEBEB"
                        Margin="24,14,24,0"/>

                <!-- FORM BODY -->
                <StackPanel Margin="32,22,32,0">

                    <!-- Info notice -->
                    <Border Background="#FFF3F3"
                            Padding="12,9"
                            Margin="0,0,0,22"
                            BorderBrush="#F5BBBB"
                            BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="ℹ"
                                       Foreground="#C0392B"
                                       FontSize="13"
                                       VerticalAlignment="Top"
                                       Margin="0,0,8,0"/>
                            <TextBlock Text="Vui lòng nhập đúng thông tin để xác nhận thông tin dịch vụ."
                                       Foreground="#C0392B"
                                       FontSize="12"
                                       FontFamily="Segoe UI"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Tên dịch vụ -->
                    <TextBlock Text="Tên dịch vụ"
                               Foreground="#333333"
                               FontSize="12"
                               FontFamily="Segoe UI"
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>
                    <Border Background="White"
                            Height="42"
                            Margin="0,0,0,14"
                            BorderBrush="#CCCCCC"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🛎️"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       FontSize="16"/>
                            <TextBox Grid.Column="1"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#222222"
                                     FontSize="13"
                                     FontFamily="Segoe UI"
                                     VerticalContentAlignment="Center"
                                     Padding="4,0,8,0"
                                     Text="{Binding TenDichVu, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </Border>

                    <!-- Đơn vị tính -->
                    <TextBlock Text="Đơn vị tính"
                               Foreground="#333333"
                               FontSize="12"
                               FontFamily="Segoe UI"
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>
                    <Border Background="White"
                            Height="42"
                            Margin="0,0,0,14"
                            BorderBrush="#CCCCCC"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="⚖️"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       FontSize="16"/>
                            <TextBox Grid.Column="1"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#222222"
                                     FontSize="13"
                                     FontFamily="Segoe UI"
                                     VerticalContentAlignment="Center"
                                     Padding="4,0,8,0"
                                     Text="{Binding DonViTinh, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </Border>

                    <!-- Đơn giá -->
                    <TextBlock Text="Đơn giá"
                               Foreground="#333333"
                               FontSize="12"
                               FontFamily="Segoe UI"
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>
                    <Border Background="White"
                            Height="42"
                            Margin="0,0,0,14"
                            BorderBrush="#CCCCCC"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="💲"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       FontSize="16"/>
                            <TextBox Grid.Column="1"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#222222"
                                     FontSize="13"
                                     FontFamily="Segoe UI"
                                     VerticalContentAlignment="Center"
                                     Padding="4,0,8,0"
                                     Text="{Binding DonGia, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </Border>

                    <!-- Tồn kho -->
                    <TextBlock Text="Tồn kho"
                               Foreground="#333333"
                               FontSize="12"
                               FontFamily="Segoe UI"
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>
                    <Border Background="White"
                            Height="42"
                            Margin="0,0,0,14"
                            BorderBrush="#CCCCCC"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="📦"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       FontSize="16"/>
                            <TextBox Grid.Column="1"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#222222"
                                     FontSize="13"
                                     FontFamily="Segoe UI"
                                     VerticalContentAlignment="Center"
                                     Padding="4,0,8,0"
                                     Text="{Binding TonKho}"/>
                        </Grid>
                    </Border>

                    <!-- Cảnh báo tồn kho -->
                    <TextBlock Text="Cảnh báo tồn kho"
                               Foreground="#333333"
                               FontSize="12"
                               FontFamily="Segoe UI"
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>
                    <Border Background="White"
                            Height="42"
                            Margin="0,0,0,24"
                            BorderBrush="#CCCCCC"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="⚠️"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       FontSize="16"/>
                            <TextBox Grid.Column="1"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#222222"
                                     FontSize="13"
                                     FontFamily="Segoe UI"
                                     VerticalContentAlignment="Center"
                                     Padding="4,0,8,0"
                                     Text="{Binding CanhBaoTonKho}"/>
                        </Grid>
                    </Border>

                    <!-- Button: Thêm hình ảnh -->
                    <Button Height="42"
                            Cursor="Hand"
                            BorderThickness="0"
                            Command="{Binding ThemHinhAnhCommand}"
                            CommandParameter="{Binding ElementName=AddDVWD}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="BtnBorder"
                                        CornerRadius="6"
                                        Height="42"
                                        Background="#27AE60">
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="➕"
                                                   Foreground="White"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,7,0"/>
                                        <TextBlock Text="THÊM HÌNH ẢNH"
                                                   Foreground="White"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   FontFamily="Segoe UI"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="BtnBorder" Property="Opacity" Value="0.87"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="BtnBorder" Property="Opacity" Value="0.72"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Button: Xác nhận -->
                    <Button Height="42"
                            Cursor="Hand"
                            BorderThickness="0"
                            Command="{Binding XacNhanCommand}"
                            CommandParameter="{Binding ElementName=AddDVWD}"
                            Margin="0,12,0,24">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="BtnConfirmBorder"
                                        CornerRadius="6"
                                        Height="42"
                                        Background="#E05555">
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="✔"
                                                   Foreground="White"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,7,0"/>
                                        <TextBlock Text="XÁC NHẬN"
                                                   Foreground="White"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   FontFamily="Segoe UI"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="BtnConfirmBorder" Property="Opacity" Value="0.87"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="BtnConfirmBorder" Property="Opacity" Value="0.72"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>
            </StackPanel>

        </Grid>
    </Border>

</Window>
