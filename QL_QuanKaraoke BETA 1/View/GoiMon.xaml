<Window x:Class="QL_QuanKaraoke_BETA_1.View.GoiMon"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QL_QuanKaraoke_BETA_1"
        mc:Ignorable="d"
        Title="GoiMon" 
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#13111F"
        ResizeMode="NoResize"
        Name="GoiMonWD"
        DataContext="{StaticResource GoiMonVM}">
    <Window.Resources>

        <!-- ══════════ COLORS / BRUSHES ══════════ -->
        <SolidColorBrush x:Key="BgDeep"        Color="#13111F"/>
        <SolidColorBrush x:Key="BgCard"        Color="#1E1C31"/>
        <SolidColorBrush x:Key="BgPanel"       Color="#22203A"/>
        <SolidColorBrush x:Key="BgChip"        Color="#2A2740"/>
        <SolidColorBrush x:Key="AccentPurple"  Color="#7C5CFC"/>
        <SolidColorBrush x:Key="AccentGreen"   Color="#4ADE80"/>
        <SolidColorBrush x:Key="AccentRed"     Color="#F87171"/>
        <SolidColorBrush x:Key="AccentAmber"   Color="#FBBF24"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#F0EEF8"/>
        <SolidColorBrush x:Key="TextMuted"     Color="#9490B0"/>
        <SolidColorBrush x:Key="BorderSubtle"  Color="#2E2B4A"/>

        <!-- ══════════ SCROLLBAR ══════════ -->
        <Style x:Key="MinimalScrollBar" TargetType="ScrollBar">
            <Setter Property="Width"      Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#3A3660"
                                                        CornerRadius="3"
                                                        Margin="1,0"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="8"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0"/>
                            <ScrollBar Grid.Column="1"
                                       Style="{StaticResource MinimalScrollBar}"
                                       Orientation="Vertical"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══════════ NUMERIC BUTTON STYLE (+ / -) ══════════ -->
        <Style x:Key="NumBtn" TargetType="Button">
            <Setter Property="Width"           Value="26"/>
            <Setter Property="Height"          Value="26"/>
            <Setter Property="FontSize"        Value="15"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Foreground"      Value="#F0EEF8"/>
            <Setter Property="Background"      Value="#2A2740"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3D3860"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#7C5CFC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══════════ CONFIRM BUTTON ══════════ -->
        <Style x:Key="BtnConfirm" TargetType="Button">
            <Setter Property="Height"          Value="44"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="12"
                                Background="#7C5CFC">
                            <Border.Effect>
                                <DropShadowEffect Color="#7C5CFC" BlurRadius="16"
                                                  ShadowDepth="0" Opacity="0.45"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.72"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══════════ RESET BUTTON ══════════ -->
        <Style x:Key="BtnReset" TargetType="Button">
            <Setter Property="Height"          Value="44"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Foreground"      Value="#9490B0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush"     Value="#2E2B4A"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="12"
                                Background="#1E1C31"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#4A4670"/>
                                <Setter Property="Foreground"  Value="#C8C4E0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══════════ ITEM CARD: HOVER EFFECT ══════════ -->
        <Style x:Key="MenuCard" TargetType="Border">
            <Setter Property="Width"           Value="200"/>
            <Setter Property="Background"      Value="#1E1C31"/>
            <Setter Property="CornerRadius"    Value="16"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush"     Value="#2E2B4A"/>
            <Setter Property="Margin"          Value="0,0,14,14"/>
            <Setter Property="Cursor"          Value="Arrow"/>
        </Style>

    </Window.Resources>

    <!-- ══════════════════════════════════════════════════════
         ROOT: 2 cột — danh sách món (trái) + panel tóm tắt (phải)
    ══════════════════════════════════════════════════════════ -->
    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Danh sách món -->
            <ColumnDefinition Width="*"/>
            <!-- Panel đặt hàng -->
            <ColumnDefinition Width="290"/>
        </Grid.ColumnDefinitions>

        <!-- ════════════════════════════════════════════
             CỘT TRÁI — Header + Lưới món ăn
        ════════════════════════════════════════════ -->
        <Grid Grid.Column="0" Margin="28,24,16,24">
            <Grid.RowDefinitions>
                <!-- Tiêu đề -->
                <RowDefinition Height="Auto"/>
                <!-- Gap -->
                <RowDefinition Height="16"/>
                <!-- Nhãn section -->
                <RowDefinition Height="Auto"/>
                <!-- Gap -->
                <RowDefinition Height="12"/>
                <!-- Grid món -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ─── Tiêu đề ─── -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Border Background="#2A2740" CornerRadius="10"
                        Padding="10,8" Margin="0,0,12,0">
                    <TextBlock Text="🍽" FontSize="20"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Gọi Món &amp; Dịch Vụ"
                               Foreground="#F0EEF8"
                               FontSize="22"
                               FontWeight="Bold"/>
                    <TextBlock Text="Chọn món và số lượng cho phòng"
                               Foreground="#9490B0"
                               FontSize="12"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- ─── Nhãn section ─── -->
            <StackPanel Grid.Row="2" Orientation="Horizontal">
                <TextBlock Text="Thực đơn"
                           Foreground="#9490B0"
                           FontSize="13"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <Border Background="#2A2740" CornerRadius="10"
                        Padding="10,3" Margin="10,0,0,0">
                    <TextBlock Text="{Binding TongSoMon, StringFormat={}{0} món}"
                               Foreground="#9490B0"
                               FontSize="11"
                               VerticalAlignment="Center"/>
                </Border>

                <Border Background="#2A2740"
                                CornerRadius="8"
                                Height="46"
                                Margin="300, 0, 10, 0">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Width="18"
                                       Height="18"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="🔍"/>

                        <TextBox Grid.Column="1" Text="{Binding TuKhoa, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="#E6E6E6"
                                         FontSize="14"
                                         VerticalContentAlignment="Center"
                                         Padding="4,0,10,0"
                                         Style="{StaticResource TextBoxTheme}"
                                         Tag="Tìm kiếm"
                                         Width="250"/>
                    </Grid>

                </Border>

            </StackPanel>

            <!-- ─── ItemsControl: lưới món ─── -->
            <ScrollViewer Grid.Row="4"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding DanhSachDichVuView}">

                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <!-- ─────────────── Template 1 card món ─────────────── -->
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>

                            <Border >

                                <!-- Hover glow -->
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource MenuCard}">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="BorderBrush" Value="#7C5CFC"/>
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="#7C5CFC"
                                                                          BlurRadius="18"
                                                                          ShadowDepth="0"
                                                                          Opacity="0.30"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <StackPanel>

                                    <!-- ── Hình ảnh món ── -->
                                    <Border CornerRadius="14,14,0,0"
                                            Height="130"
                                            ClipToBounds="True">
                                        <Image Source="{Binding HinhAnhBitmap}"
                                               Stretch="UniformToFill">
                                            <!-- Fallback khi không có ảnh -->
                                            <Image.Style>
                                                <Style TargetType="Image">
                                                    <Style.Triggers>
                                                        <Trigger Property="Source" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                                
                                            </Image.Style>
                                        </Image>
                                        <!-- Placeholder khi null -->
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#2A2740"/>
                                            </Style>
                                        </Border.Style>
                                    </Border>

                                    <!-- Overlay icon khi không có ảnh (luôn nằm sau Image) -->
                                    <!-- dùng Grid chồng để hiện icon placeholder -->

                                    <!-- ── Nội dung bên dưới ảnh ── -->
                                    <StackPanel Margin="12,10,12,12">

                                        <!-- Tên món -->
                                        <TextBlock Text="{Binding TenDichVu}"
                                                   Foreground="#F0EEF8"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   TextWrapping="Wrap"
                                                   MaxHeight="38"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <!-- Đơn vị tính -->
                                        <TextBlock Text="{Binding DonViTinh}"
                                                   Foreground="#9490B0"
                                                   FontSize="11"
                                                   Margin="0,2,0,6"/>

                                        <!-- ── Giá + Tồn kho ── -->
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Giá -->
                                            <StackPanel Grid.Column="0"
                                                        VerticalAlignment="Center">
                                                <TextBlock Foreground="#9490B0"
                                                           FontSize="10"
                                                           Text="Đơn giá"/>
                                                <TextBlock Text="{Binding DonGia, StringFormat={}{0:N0}đ}"
                                                           Foreground="#7C5CFC"
                                                           FontSize="13"
                                                           FontWeight="Bold"/>
                                            </StackPanel>

                                            <!-- Tồn kho -->
                                            <Border Grid.Column="1"
                                                    CornerRadius="8"
                                                    Padding="7,3"
                                                    VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#1A3A28"/>
                                                        <Style.Triggers>
                                                            <!-- Cảnh báo tồn kho thấp (binding tạm) -->
                                                            <DataTrigger Binding="{Binding TonKhoThap}" Value="True">
                                                                <Setter Property="Background" Value="#3A1A1A"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock FontSize="10"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,4,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text"       Value="📦"/>
                                                                <Setter Property="Foreground" Value="#4ADE80"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding TonKhoThap}" Value="True">
                                                                        <Setter Property="Foreground" Value="#F87171"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding TonKho}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#4ADE80"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding TonKhoThap}" Value="True">
                                                                        <Setter Property="Foreground" Value="#F87171"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <!-- ── Divider ── -->
                                        <Border Height="1"
                                                Background="#2E2B4A"
                                                Margin="0,0,0,10"/>

                                        <!-- ── Numeric stepper ── -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Nút giảm -->
                                            <Button Grid.Column="0"
                                                    Style="{StaticResource NumBtn}"
                                                    Content="−"
                                                    Command="{Binding DataContext.GiamSoLuongCommand,
                                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    />

                                            <!-- Số lượng -->
                                            <Border Grid.Column="1"
                                                    Background="#13111F"
                                                    CornerRadius="6"
                                                    Margin="6,0"
                                                    Padding="4,2">
                                                <TextBlock Text="{Binding SoLuong}"
                                                           Foreground="#F0EEF8"
                                                           FontSize="14"
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- Nút tăng -->
                                            <Button Grid.Column="2"
                                                    Style="{StaticResource NumBtn}"
                                                    Content="+"
                                                    Command="{Binding DataContext.TangSoLuongCommand,
                                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>

                                    </StackPanel>
                                </StackPanel>
                            </Border>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>

                </ItemsControl>
            </ScrollViewer>

        </Grid>

        <!-- ════════════════════════════════════════════
             ĐƯỜNG KẺ PHÂN CÁCH
        ════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Width="1"
                Background="#2E2B4A"
                HorizontalAlignment="Right"
                Margin="0,16,0,16"/>

        <!-- ════════════════════════════════════════════
             CỘT PHẢI — Panel Tóm tắt đơn hàng
        ════════════════════════════════════════════ -->
        <Grid Grid.Column="1"
              Background="#1A1829"
              Margin="0">

            <Grid Margin="20,24,20,24">
                <Grid.RowDefinitions>
                    <!-- Tiêu đề panel -->
                    <RowDefinition Height="Auto"/>
                    <!-- Gap -->
                    <RowDefinition Height="16"/>
                    <!-- Thông tin phòng -->
                    <RowDefinition Height="Auto"/>
                    <!-- Gap -->
                    <RowDefinition Height="16"/>
                    <!-- Label -->
                    <RowDefinition Height="Auto"/>
                    <!-- Gap -->
                    <RowDefinition Height="10"/>
                    <!-- Danh sách món đã chọn -->
                    <RowDefinition Height="*"/>
                    <!-- Divider -->
                    <RowDefinition Height="Auto"/>
                    <!-- Tổng tiền -->
                    <RowDefinition Height="Auto"/>
                    <!-- Gap -->
                    <RowDefinition Height="16"/>
                    <!-- Buttons -->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ─── Tiêu đề panel ─── -->
                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <TextBlock Text="📋" FontSize="16" VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <TextBlock Text="Đơn gọi món"
                               Foreground="#F0EEF8"
                               FontSize="16"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- ─── Thông tin phòng ─── -->
                <Border Grid.Row="2"
                        Background="#22203A"
                        CornerRadius="12"
                        Padding="14,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Phòng đang phục vụ"
                                       Foreground="#9490B0"
                                       FontSize="11"/>
                            <TextBlock Text="{Binding TenPhong}"
                                       Foreground="#F0EEF8"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1"
                                Background="#1E3A50"
                                CornerRadius="8"
                                Padding="8,4"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding LoaiPhong}"
                                       Foreground="#38BDF8"
                                       FontSize="11"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- ─── Label: Món đã chọn ─── -->
                <TextBlock Grid.Row="4"
                           Text="Món đã chọn"
                           Foreground="#9490B0"
                           FontSize="12"
                           FontWeight="SemiBold"/>

                <!-- ─── Danh sách món đã chọn ─── -->
                <ScrollViewer Grid.Row="6"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding DanhSachDaChon}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding TenDichVu}"
                                                   Foreground="#F0EEF8"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Foreground="#9490B0"
                                                   FontSize="11"
                                                   Margin="0,1,0,0">
                                            <Run Text="x"/>
                                            <Run Text="{Binding SoLuong, Mode=OneWay}"/>
                                            <Run Text=" · "/>
                                            <Run Text="{Binding DonGia, StringFormat={}{0:N0}đ}"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding ThanhTien, StringFormat={}{0:N0}đ}"
                                               Foreground="#7C5CFC"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- ─── Divider ─── -->
                <Border Grid.Row="7"
                        Height="1"
                        Background="#2E2B4A"
                        Margin="0,10"/>

                <!-- ─── Tổng tiền ─── -->
                <Grid Grid.Row="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Tổng cộng"
                                   Foreground="#9490B0"
                                   FontSize="12"/>
                        <TextBlock Text="{Binding TongSoMonDaGoi, StringFormat={}{0} món}"
                                   Foreground="#9490B0"
                                   FontSize="11"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Text="{Binding TongTien, StringFormat={}{0:N0}đ}"
                               Foreground="#F0EEF8"
                               FontSize="20"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- ─── Buttons: Xác Nhận + Reset ─── -->
                <StackPanel Grid.Row="10">
                    <Button Content="✔  Xác Nhận Gọi Món"
                            Style="{StaticResource BtnConfirm}"
                            CommandParameter="{Binding ElementName=GoiMonWD}"
                            Command="{Binding XacNhanCommand}"/>
                    <Button Content="↺  Đặt Lại"
                            Style="{StaticResource BtnReset}"
                            Command="{Binding DatLaiCommand}"
                            Margin="0,8,0,0"/>
                </StackPanel>

            </Grid>
        </Grid>

    </Grid>

</Window>
