<Window x:Class="QL_QuanKaraoke_BETA_1.View.GoiMon"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        mc:Ignorable="d" 
        Title="GoiMon" 
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Name="GoiMonWD"
        Background="#F5F5F5"
        DataContext="{StaticResource GoiMonVM}">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="GỌI MÓN &amp; DỊCH VỤ" FontSize="24" FontWeight="Bold" Foreground="Black" Margin="0,0,0,5"/>
            <TextBlock Grid.Row="0" Text="Chọn món và số lượng cho phòng" Foreground="DarkGray" Margin="0,30,0,15"/>

            <Grid Grid.Row="1" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Thực đơn: " FontWeight="Bold"/>
                    <TextBlock Text="{Binding TongSoMon, StringFormat={}{0} món}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Tìm kiếm:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox Width="200" Height="25" Text="{Binding TuKhoa, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" Padding="5,0"/>
                </StackPanel>
            </Grid>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding DanhSachDichVuView}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="Gray" BorderThickness="1" Background="White" Width="200" Margin="0,0,10,10">
                                <StackPanel>

                                    <Border Height="130" BorderBrush="LightGray" BorderThickness="0,0,0,1">
                                        <Image Source="{Binding HinhAnhBitmap}" Stretch="UniformToFill">
                                            <Image.Style>
                                                <Style TargetType="Image">
                                                    <Style.Triggers>
                                                        <Trigger Property="Source" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                    </Border>

                                    <StackPanel Margin="10">
                                        <TextBlock Text="{Binding TenDichVu}" FontWeight="Bold" FontSize="14" TextWrapping="Wrap" MaxHeight="40" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding DonViTinh}" Foreground="Gray" FontSize="12" Margin="0,2,0,5"/>

                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Đơn giá" FontSize="11" Foreground="Gray"/>
                                                <TextBlock Text="{Binding DonGia, StringFormat={}{0:N0}đ}" Foreground="Blue" FontWeight="Bold" FontSize="14"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Orientation="Horizontal">
                                                <TextBlock Text="Kho: " FontSize="12" Foreground="Gray"/>
                                                <TextBlock Text="{Binding TonKho}" FontSize="12" FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="Green"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding TonKhoThap}" Value="True">
                                                                    <Setter Property="Foreground" Value="Red"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>

                                        <Border Height="1" Background="LightGray" Margin="0,0,0,10"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="30"/>
                                            </Grid.ColumnDefinitions>

                                            <Button Grid.Column="0" Content="-" FontWeight="Bold" Background="#E0E0E0" BorderThickness="1" BorderBrush="Gray"
                                                    Command="{Binding DataContext.GiamSoLuongCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                    CommandParameter="{Binding}"/>

                                            <TextBlock Grid.Column="1" Text="{Binding SoLuong}" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                            <Button Grid.Column="2" Content="+" FontWeight="Bold" Background="#E0E0E0" BorderThickness="1" BorderBrush="Gray"
                                                    Command="{Binding DataContext.TangSoLuongCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Background="White" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="ĐƠN GỌI MÓN" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

                <Border Grid.Row="1" BorderBrush="LightGray" BorderThickness="1" Background="#F9F9F9" Padding="10" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Phòng đang phục vụ" Foreground="Gray" FontSize="12"/>
                            <TextBlock Text="{Binding TenPhong}" FontWeight="Bold" FontSize="16"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{Binding LoaiPhong}" Foreground="Blue" FontWeight="Bold" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <TextBlock Grid.Row="2" Text="Món đã chọn:" FontWeight="Bold" Margin="0,0,0,10"/>

                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding DanhSachDaChon}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding TenDichVu}" FontWeight="SemiBold"/>
                                        <TextBlock Foreground="Gray" FontSize="12">
                                            <Run Text="SL: "/>
                                            <Run Text="{Binding SoLuong, Mode=OneWay}"/>
                                            <Run Text=" x "/>
                                            <Run Text="{Binding DonGia, StringFormat={}{0:N0}đ}"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding ThanhTien, StringFormat={}{0:N0}đ}" Foreground="Blue" FontWeight="Bold" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border Grid.Row="4" Height="1" Background="Gray" Margin="0,15,0,15"/>

                <StackPanel Grid.Row="5">
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="TỔNG CỘNG" FontWeight="Bold"/>
                            <TextBlock Text="{Binding TongSoMonDaGoi, StringFormat={}({0} món)}" Foreground="Gray" FontSize="12"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{Binding TongTien, StringFormat={}{0:N0} đ}" Foreground="Red" FontSize="20" FontWeight="Bold"/>
                    </Grid>

                    <Button Content="XÁC NHẬN GỌI MÓN" Height="40" Background="#4CAF50" Foreground="White" FontWeight="Bold" BorderThickness="0"
                            CommandParameter="{Binding ElementName=GoiMonWD}"
                            Command="{Binding XacNhanCommand}" Margin="0,0,0,10"/>

                    <Button Content="ĐẶT LẠI" Height="35" Background="White" BorderBrush="Gray" BorderThickness="1"
                            Command="{Binding DatLaiCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>