<Window x:Class="QL_QuanKaraoke_BETA_1.View.DoiMatKhauWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:local="clr-namespace:QL_QuanKaraoke_BETA_1.ClassTheme"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:k="clr-namespace:QL_QuanKaraoke_BETA_1"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        Height="380"
        Width="440"
        Name="ChangePasswordWD"
        AllowsTransparency="True"
        Title="DoiMatKhauWindow" DataContext="{StaticResource DoiMatKhauVM}">
    <Border CornerRadius="20" Background="#1A1A2E">

        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="0" Opacity="0.6"/>
        </Border.Effect>

        <Grid>

            <!-- Đường viền gradient trên cùng -->
            <Border Height="3"
                    VerticalAlignment="Top"
                    CornerRadius="20,20,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#F07070" Offset="0"/>
                        <GradientStop Color="#F9A8A8" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <StackPanel>

                <!-- HEADER -->
                <Grid Margin="24,20,24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="36" Height="36"
                                CornerRadius="10"
                                Margin="0,0,12,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#F07070" Offset="0"/>
                                    <GradientStop Color="#F9A8A8" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Image Source="/image/padlock.png"
                                   Width="16" Height="18"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="ĐỔI MẬT KHẨU"
                                       Foreground="#F07070"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       FontFamily="Segoe UI"/>
                            <TextBlock Text="Nhập mật khẩu mới cho tài khoản"
                                       Foreground="#888899"
                                       FontSize="11"
                                       FontFamily="Segoe UI"/>
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="1" Command="{Binding ExitCommand}"
                            CommandParameter="{Binding ElementName=ChangePasswordWD}"
                            Style="{StaticResource CloseButtonStyle}"
                            VerticalAlignment="Top"/>
                </Grid>

                <!-- DIVIDER -->
                <Border Height="1"
                        Background="#2A2A40"
                        Margin="24,16,24,0"/>

                <!-- FORM -->
                <StackPanel Margin="32,28,32,0">

                    <!-- MẬT KHẨU MỚI -->
                    <TextBlock Text="Mật khẩu mới"
                               Foreground="#CCCCDD"
                               FontSize="12"
                               FontWeight="SemiBold"
                               FontFamily="Segoe UI"
                               Margin="0,0,0,6"/>

                    <Border Background="#353340"
                            CornerRadius="8"
                            Height="46"
                            Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <Image Source="/image/padlock.png"
                                   Width="16" Height="18"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Opacity="0.7"/>

                            <PasswordBox Grid.Column="1"
                                         x:Name="TxtNewPassword"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         FontSize="13"
                                         FontFamily="Segoe UI"
                                         VerticalContentAlignment="Center"
                                         Style="{StaticResource PasswordBoxTheme}"
                                         Tag="Nhập mật khẩu mới"
                                         local:PasswordHelper.MonitorPassword="True">

                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="PasswordChanged">
                                        <i:InvokeCommandAction Command="{Binding PasswordChangedCommand}" CommandParameter="{Binding ElementName=TxtNewPassword}" />
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </PasswordBox>
                        </Grid>
                    </Border>

                    <!-- XÁC NHẬN MẬT KHẨU MỚI -->
                    <TextBlock Text="Xác nhận mật khẩu mới"
                               Foreground="#CCCCDD"
                               FontSize="12"
                               FontWeight="SemiBold"
                               FontFamily="Segoe UI"
                               Margin="0,0,0,6"/>

                    <Border Background="#353340"
                            CornerRadius="8"
                            Height="46"
                            Margin="0,0,0,28">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <Image Source="/image/padlock.png"
                                   Width="16" Height="18"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Opacity="0.7"/>

                            <PasswordBox Grid.Column="1"
                                         x:Name="TxtConfirmPassword"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         FontSize="13"
                                         FontFamily="Segoe UI"
                                         VerticalContentAlignment="Center"
                                         Style="{StaticResource PasswordBoxTheme}"
                                         Tag="Xác nhận mật khẩu mới"
                                         local:PasswordHelper.MonitorPassword="True">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="PasswordChanged">
                                        <i:InvokeCommandAction Command="{Binding PasswordConfirmChangedCommand}" CommandParameter="{Binding ElementName=TxtConfirmPassword}" />
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </PasswordBox>
                        </Grid>
                    </Border>

                    <!-- BUTTON XÁC NHẬN -->
                    <Button Height="46"
                            Cursor="Hand"
                            BorderThickness="0"
                            Command="{Binding XacNhanCommand}"
                            CommandParameter="{Binding ElementName=ChangePasswordWD}">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">

                                <Border x:Name="ConfirmBorder"
                                        CornerRadius="8"
                                        Height="46">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#F07070" Offset="0"/>
                                            <GradientStop Color="#F9A8A8" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>

                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="✔"
                                                   Foreground="White"
                                                   FontSize="14"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"/>
                                        <TextBlock Text="XÁC NHẬN"
                                                   Foreground="White"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   FontFamily="Segoe UI"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ConfirmBorder" Property="Opacity" Value="0.88"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="ConfirmBorder" Property="Opacity" Value="0.72"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>

                            </ControlTemplate>
                        </Button.Template>

                    </Button>

                </StackPanel>

            </StackPanel>

        </Grid>
    </Border>
</Window>
