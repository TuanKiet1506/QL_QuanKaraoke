<UserControl x:Class="QL_QuanKaraoke_BETA_1.View.DatPhongUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:QL_QuanKaraoke_BETA_1.Converters"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Background="#F0F0F0"
             DataContext="{StaticResource DatPhongVM}">

    <UserControl.Resources>
        <!-- Converters -->
        <conv:TrangThaiToBrushConverter  x:Key="TrangThaiToBrush"/>
        <conv:TrangThaiToLabelConverter  x:Key="TrangThaiToLabel"/>
        <conv:TrangThaiToDotConverter    x:Key="TrangThaiToDot"/>

        <!-- Style: ô thống kê -->
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background"    Value="White"/>
            <Setter Property="BorderBrush"   Value="#DDDDDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"  Value="0"/>
            <Setter Property="Padding"       Value="0,16"/>
            <Setter Property="Margin"        Value="0,0,10,0"/>
        </Style>

        <!-- Style: số lớn trong stat -->
        <Style x:Key="StatNum" TargetType="TextBlock">
            <Setter Property="Foreground"          Value="#222222"/>
            <Setter Property="FontSize"            Value="28"/>
            <Setter Property="FontWeight"          Value="Medium"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <!-- Style: nhãn nhỏ dưới số -->
        <Style x:Key="StatLabel" TargetType="TextBlock">
            <Setter Property="Foreground"          Value="#666666"/>
            <Setter Property="FontSize"            Value="11"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin"              Value="0,4,0,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <!-- Tiêu đề -->
            <RowDefinition Height="Auto"/>
            <!-- Khoảng cách -->
            <RowDefinition Height="14"/>
            <!-- Stats bar -->
            <RowDefinition Height="Auto"/>
            <!-- Khoảng cách -->
            <RowDefinition Height="18"/>
            <!-- Nhãn section -->
            <RowDefinition Height="Auto"/>
            <!-- Khoảng cách -->
            <RowDefinition Height="10"/>
            <!-- Danh sách phòng -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══════════════ ROW 0 — Tiêu đề ══════════════ -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="🎤"
                       FontSize="20"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>
            <TextBlock Text="Đặt Phòng"
                       Foreground="#111111"
                       FontSize="20"
                       FontWeight="Medium"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- ══════════════ ROW 2 — Stats Bar ══════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <!-- Tổng phòng -->
            <Border Grid.Column="0" Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="{Binding TongPhong}"
                               Style="{StaticResource StatNum}"/>
                    <TextBlock Text="Tổng phòng"
                               Style="{StaticResource StatLabel}"/>
                </StackPanel>
            </Border>

            <!-- Đang trống -->
            <Border Grid.Column="1" Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="{Binding SoPhongTrong}"
                               Style="{StaticResource StatNum}"
                               Foreground="#16A34A"/>
                    <TextBlock Text="Đang trống"
                               Style="{StaticResource StatLabel}"/>
                </StackPanel>
            </Border>

            <!-- Đang dùng -->
            <Border Grid.Column="2" Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="{Binding SoPhongDangDung}"
                               Style="{StaticResource StatNum}"
                               Foreground="#DC2626"/>
                    <TextBlock Text="Đang dùng"
                               Style="{StaticResource StatLabel}"/>
                </StackPanel>
            </Border>

            <!-- Dọn dẹp + Bảo trì -->
            <Border Grid.Column="3" Style="{StaticResource StatCard}" Margin="0">
                <StackPanel>
                    <TextBlock Text="{Binding SoPhongKhac}"
                               Style="{StaticResource StatNum}"
                               Foreground="#D97706"/>
                    <TextBlock Text="Dọn dẹp / Bảo trì"
                               Style="{StaticResource StatLabel}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ══════════════ ROW 4 — Nhãn section ══════════════ -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="Danh sách phòng"
                       Foreground="#555555"
                       FontSize="13"
                       VerticalAlignment="Center"/>
            <Border Background="#E0E0E0"
                    CornerRadius="0"
                    Padding="8,2"
                    Margin="8,0,0,0">
                <TextBlock Text="{Binding TongPhong, StringFormat={}{0} phòng}"
                           Foreground="#555555"
                           FontSize="11"
                           VerticalAlignment="Center"/>
            </Border>
        </StackPanel>

        <!-- ══════════════ ROW 6 — Room Cards ══════════════ -->
        <ScrollViewer Grid.Row="6"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding DanhSachPhong}">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <!-- ───── Template 1 ô phòng ───── -->
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                Cursor="Hand"
                                Command="{Binding DataContext.MoMenuCommand,
                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}">

                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Button.Template>

                            <Border Width="180" Height="118"
                                    Margin="0,0,12,12"
                                    CornerRadius="0"
                                    Background="White"
                                    BorderThickness="2"
                                    BorderBrush="{Binding TrangThai,
                                                  Converter={StaticResource TrangThaiToBrush}}">

                                <Grid Margin="12,10,12,10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Dòng 1: Badge loại phòng + Tên phòng -->
                                    <StackPanel Grid.Row="0"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center">

                                        <Border CornerRadius="0"
                                                Padding="6,2"
                                                Margin="0,0,8,0"
                                                Background="{Binding TrangThai,
                                                             Converter={StaticResource TrangThaiToBrush}}">
                                            <TextBlock Text="{Binding LoaiPhong.TenLoai}"
                                                       Foreground="White"
                                                       FontSize="10"
                                                       FontWeight="Medium"/>
                                        </Border>

                                        <TextBlock Text="{Binding TenPhong}"
                                                   Foreground="#111111"
                                                   FontSize="18"
                                                   FontWeight="Medium"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Dòng 2: Sức chứa -->
                                    <StackPanel Grid.Row="1"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center"
                                                Margin="0,6,0,0">
                                        <TextBlock Text="👥  "
                                                   FontSize="12"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Foreground="#666666"
                                                   FontSize="12"
                                                   VerticalAlignment="Center">
                                            <Run Text="Sức chứa: "/>
                                            <Run Text="{Binding SucChua}"
                                                 Foreground="#111111"
                                                 FontWeight="Medium"/>
                                            <Run Text=" người"
                                                 Foreground="#666666"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Dòng 3: Trạng thái (không có border, để thẳng) -->
                                    <StackPanel Grid.Row="2"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding TrangThai,
                                                       Converter={StaticResource TrangThaiToDot}}"
                                                   FontSize="9"
                                                   Foreground="{Binding TrangThai,
                                                                Converter={StaticResource TrangThaiToBrush}}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,5,0"/>
                                        <TextBlock Text="{Binding TrangThai,
                                                       Converter={StaticResource TrangThaiToLabel}}"
                                                   FontSize="12"
                                                   FontWeight="Medium"
                                                   Foreground="{Binding TrangThai,
                                                                Converter={StaticResource TrangThaiToBrush}}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>

                                </Grid>
                            </Border>

                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>

            </ItemsControl>
        </ScrollViewer>

    </Grid>

</UserControl>
