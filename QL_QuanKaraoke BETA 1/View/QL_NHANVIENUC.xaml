<UserControl x:Class="QL_QuanKaraoke_BETA_1.View.QL_NHANVIENUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QL_QuanKaraoke_BETA_1"
             mc:Ignorable="d" 
             d:DesignHeight="650" d:DesignWidth="950"
             Background="White"
             DataContext="{StaticResource QL_NhanVienVM}">

    <Grid Margin="24,20,24,20">
        <Grid.RowDefinitions>
            <!-- Tiêu đề -->
            <RowDefinition Height="Auto"/>
            <!-- Gap -->
            <RowDefinition Height="16"/>
            <!-- Input: HoTen + SoDienThoai -->
            <RowDefinition Height="Auto"/>
            <!-- Gap -->
            <RowDefinition Height="12"/>
            <!-- Toolbar: Filter + Search -->
            <RowDefinition Height="Auto"/>
            <!-- Gap -->
            <RowDefinition Height="12"/>
            <!-- ListView -->
            <RowDefinition Height="*"/>
            <!-- Gap -->
            <RowDefinition Height="12"/>
            <!-- Buttons -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══════════ ROW 0 — Tiêu đề ══════════ -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="👤" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"
                       Foreground="#F88888"/>
            <TextBlock Text="Quản Lý Nhân Viên"
                       Foreground="#F88888"
                       FontSize="20"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- ══════════ ROW 2 — Input HoTen + SoDienThoai ══════════ -->
        <Border Grid.Row="2"
                Background="#F9F9F9"
                BorderThickness="1"
                BorderBrush="#DDDDDD"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="28"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="28"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="160"/>
                </Grid.ColumnDefinitions>

                <!-- Họ tên -->
                <TextBlock Grid.Column="0"
                           Text="Họ &amp; Tên"
                           Foreground="Black"
                           FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <Border Grid.Column="1"
                        Background="White"
                        Height="28"
                        BorderBrush="#CCCCCC"
                        BorderThickness="1">
                    <TextBox Background="Transparent"
                             BorderThickness="0"
                             Foreground="#222222"
                             FontSize="13"
                             FontFamily="Segoe UI"
                             VerticalContentAlignment="Center"
                             Padding="6,0,6,0"
                             IsReadOnly="True"
                             Text="{Binding SelectedNhanVien.HoTen}"/>
                </Border>

                <!-- Số điện thoại -->
                <TextBlock Grid.Column="3"
                           Text="Số Điện Thoại"
                           Foreground="Black"
                           FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <Border Grid.Column="4"
                        Background="White"
                        Height="28"
                        BorderBrush="#CCCCCC"
                        BorderThickness="1">
                    <TextBox Background="Transparent"
                             BorderThickness="0"
                             Foreground="#222222"
                             FontSize="13"
                             FontFamily="Segoe UI"
                             VerticalContentAlignment="Center"
                             Padding="6,0,6,0"
                             IsReadOnly="True"
                             Text="{Binding SelectedNhanVien.SoDienThoai}"/>
                </Border>

                <!-- Chức vụ -->
                <TextBlock Grid.Column="6"
                           Text="Chức Vụ"
                           Foreground="Black"
                           FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <Border Grid.Column="7"
                        Background="White"
                        Height="28"
                        BorderBrush="#CCCCCC"
                        BorderThickness="1">
                    <TextBox Background="Transparent"
                             BorderThickness="0"
                             Foreground="#222222"
                             FontSize="13"
                             FontFamily="Segoe UI"
                             VerticalContentAlignment="Center"
                             Padding="6,0,6,0"
                             IsReadOnly="True"
                             Text="{Binding SelectedNhanVien.ChucVu}"/>
                </Border>
            </Grid>
        </Border>

        <!-- ══════════ ROW 4 — Filter + Search ══════════ -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ComboBox lọc trạng thái — dùng mặc định WPF -->
            <ComboBox Grid.Column="0"
                      Height="36"
                      FontSize="13"
                      FontFamily="Segoe UI"
                      VerticalContentAlignment="Center"
                      ItemsSource="{Binding DSTrangThai, UpdateSourceTrigger=PropertyChanged}"
                      SelectedItem="{Binding TrangThaiDangChon, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- TextBox tìm kiếm -->
            <Border Grid.Column="2"
                    Background="White"
                    Height="36"
                    BorderBrush="#CCCCCC"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="36"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="🔍 "
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="14"/>
                    <TextBox Grid.Column="1"
                             Text="{Binding TuKhoa, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#222222"
                             FontSize="13"
                             FontFamily="Segoe UI"
                             VerticalContentAlignment="Center"
                             Padding="4,0,8,0"
                             />
                </Grid>
            </Border>
        </Grid>

        <!-- ══════════ ROW 6 — ListView (mặc định WPF) ══════════ -->
        <ListView Grid.Row="6"
                  BorderBrush="#CCCCCC"
                  BorderThickness="1"
                  FontSize="13"
                  FontFamily="Segoe UI"
                  ItemsSource="{Binding DanhSachNhanVienView, UpdateSourceTrigger=PropertyChanged}"
                  SelectedItem="{Binding SelectedNhanVien}">

            <ListView.View>
                <GridView>

                    <!-- Mã NV -->
                    <GridViewColumn Header="Mã NV" Width="70">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding MaNhanVien}" Padding="14,10"
                                           FontWeight="SemiBold"
                                           FontSize="12"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Tên đăng nhập -->
                    <GridViewColumn Header="Tên đăng nhập" Width="130">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding TenDangNhap}" Padding="14,10"
                                           Foreground="#FFC3295E"
                                           FontWeight="SemiBold"
                                           FontSize="12"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Họ tên -->
                    <GridViewColumn Header="Họ &amp; Tên" Width="160">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding HoTen}"
                                           FontWeight="SemiBold"
                                           Padding="14,10"
                                           Foreground="#7C5CFC"
                                           FontSize="12"
                                           />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Số điện thoại -->
                    <GridViewColumn Header="Số điện thoại" Width="120">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding SoDienThoai}" Padding="14,10"
                                           Foreground="Black"
                                           FontSize="12"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Chức vụ -->
                    <GridViewColumn Header="Chức vụ" Width="110">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ChucVu}" Padding="14,10"
                                           Foreground="Black"
                                           FontSize="12"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="Trạng thái" Width="160">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock x:Name="TrangThaiText"
                                           Text="{Binding TrangThai}" Foreground="Black"
                                           Padding="14,10"
                                           FontSize="12"
                                           FontWeight="Bold"/>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding TrangThai}" Value="0">
                                        <Setter TargetName="TrangThaiText" Property="Text" Value="Bị khóa tài khoản"/>
                                        <Setter TargetName="TrangThaiText" Property="Foreground" Value="#DC2626"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding TrangThai}" Value="1">
                                        <Setter TargetName="TrangThaiText" Property="Text" Value="Đang làm việc"/>
                                        <Setter TargetName="TrangThaiText" Property="Foreground" Value="#16A34A"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding TrangThai}" Value="2">
                                        <Setter TargetName="TrangThaiText" Property="Text" Value="Đã nghỉ việc"/>
                                        <Setter TargetName="TrangThaiText" Property="Foreground" Value="#7C5CFC"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                </GridView>
            </ListView.View>
        </ListView>

        <!-- ══════════ ROW 8 — Buttons (giữ nguyên) ══════════ -->
        <Grid Grid.Row="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Thêm -->
            <Button Grid.Column="0"
                    Content="➕  Thêm"
                    Height="40"
                    Command="{Binding ThemCommand}">
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#16A34A" Offset="0"/>
                        <GradientStop Color="#4ADE80" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>
            </Button>

            <!-- Sửa -->
            <Button Grid.Column="2"
                    Content="✏  Sửa"
                    Height="40"
                    Command="{Binding SuaCommand}">
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1D4ED8" Offset="0"/>
                        <GradientStop Color="#38BDF8" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>
            </Button>

            <!-- Khóa tài khoản -->
            <Button Grid.Column="4"
                    Height="40"
                    Command="{Binding KhoaTaiKhoanCommand}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔒  " VerticalAlignment="Center"/>
                    <TextBlock Text="Khóa TK" VerticalAlignment="Center"/>
                </StackPanel>
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#DC2626" Offset="0"/>
                        <GradientStop Color="#F87171" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>
            </Button>

            <!-- Mở khóa -->
            <Button Grid.Column="6"
                    Height="40"
                    Command="{Binding MoKhoaCommand}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔓  " VerticalAlignment="Center"/>
                    <TextBlock Text="Mở khóa" VerticalAlignment="Center"/>
                </StackPanel>
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0D9488" Offset="0"/>
                        <GradientStop Color="#34D399" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>
            </Button>

            <!-- Reset mật khẩu -->
            <Button Grid.Column="8"
                    Height="40"
                    Command="{Binding ResetMatKhauCommand}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔑  " VerticalAlignment="Center"/>
                    <TextBlock Text="Reset MK" VerticalAlignment="Center"/>
                </StackPanel>
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#D97706" Offset="0"/>
                        <GradientStop Color="#FBBF24" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>
            </Button>

            <!-- Xác nhận nghỉ việc -->
            <Button Grid.Column="10"
                    Height="40"
                    Command="{Binding XacNhanNghiViecCommand}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🚪  " VerticalAlignment="Center"/>
                    <TextBlock Text="Nghỉ việc" VerticalAlignment="Center"/>
                </StackPanel>
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#4B4568" Offset="0"/>
                        <GradientStop Color="#7C6F9E" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>
            </Button>

        </Grid>

    </Grid>

</UserControl>
