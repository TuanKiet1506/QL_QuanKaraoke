<UserControl x:Class="QL_QuanKaraoke_BETA_1.View.QL_HangThanhVienUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cv="clr-namespace:QL_QuanKaraoke_BETA_1.Converters"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QL_QuanKaraoke_BETA_1"
             mc:Ignorable="d" Background="White"
             d:DesignHeight="450" d:DesignWidth="800" DataContext="{StaticResource QLHangThanhVienVM}">

    <Grid Margin="24,20,24,20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="347*"/>
            <ColumnDefinition Width="405*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <!-- Tiêu đề -->
            <RowDefinition Height="Auto"/>
            <!-- Gap -->
            <RowDefinition Height="20"/>
            <!-- Input: HoTen + SoDienThoai -->
            <RowDefinition Height="Auto"/>
            <!-- Gap -->
            <RowDefinition Height="14"/>
            <!-- Toolbar: Filter + Search -->
            <RowDefinition Height="Auto"/>
            <!-- Gap -->
            <RowDefinition Height="14"/>
            <!-- ListView -->
            <RowDefinition Height="*"/>
            <!-- Gap -->
            <RowDefinition Height="14"/>
            <!-- Buttons -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══════════ ROW 0 — Tiêu đề ══════════ -->
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.ColumnSpan="2">
            <TextBlock Text="👑" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#F88888"/>
            <TextBlock Text="Quản Lý Hạng Thành Viên"
                       Foreground="#F88888"
                       FontSize="22"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- ══════════ ROW 2 — Input HoTen + SoDienThoai ══════════ -->
        <Border Grid.Row="1"
                Background="#F9F9F9"
                BorderThickness="1.5"
                BorderBrush="#DDDDDD"
                Padding="20,16" Grid.ColumnSpan="2" Margin="0,20,0,0" Grid.RowSpan="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="32"/>
                </Grid.ColumnDefinitions>

                <!-- Họ tên -->
                <TextBlock Grid.Column="0"
                           Text="Tên Hạng"
                           Foreground="Black"
                           FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <Border Background="White"
                        Height="25"
                        Margin="0,0,0,0" 
                        Grid.Column="1"
                        BorderBrush="#CCCCCC"
                        BorderThickness="1">
                    <Grid>
                        <TextBox
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="Black"
                             FontSize="14"
                             VerticalContentAlignment="Center"
                             Padding="4,0,10,0"
                             IsReadOnly="True"
                             Text="{Binding TenHang}"
                     />
                    </Grid>
                </Border>

                <!-- Số điện thoại -->
                <TextBlock Grid.Column="3"
                           Text="Phần Trăm Giảm Giá"
                           Foreground="Black"
                           FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <Border Background="White"
                           Height="25"
                           Margin="0,0,0,0" 
                           Grid.Column="4"
                        BorderBrush="#CCCCCC"
                        BorderThickness="1"
                                           >
                    <Grid>
                        <TextBox
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="Black"
                                FontSize="14"
                                VerticalContentAlignment="Center"
                                Padding="4,0,10,0"
                                IsReadOnly="True"
                                Text="{Binding Ptgg}"
                                   />
                    </Grid>
                </Border>

            </Grid>
        </Border>

        <!-- ══════════ ROW 4 — Filter + Search ══════════ -->
        <Grid Grid.Row="3" Grid.ColumnSpan="2" Margin="0,14,0,0" Grid.RowSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ComboBox lọc trạng thái -->
            <ComboBox Grid.Column="0"
          Height="38"
          ItemsSource="{Binding DSHangFilter, UpdateSourceTrigger=PropertyChanged}"
          SelectedItem="{Binding HangDangChon, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
          DisplayMemberPath="TenHang"
          />

            <!-- TextBox tìm kiếm -->
            <Grid Grid.Column="2">
                <Border Background="White"
                Height="46"
                Margin="0"
                        BorderBrush="#CCCCCC"
                        BorderThickness="1">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Width="18"
                       Height="18"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Text="🔍"/>

                        <TextBox Grid.Column="1" Text="{Binding TuKhoa, UpdateSourceTrigger=PropertyChanged}"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="Black"
                         FontSize="14"
                         VerticalContentAlignment="Center"
                         Padding="4,0,10,0"
                         Margin="0,0,-5,0"/>
                    </Grid>

                </Border>
            </Grid>
        </Grid>

        <!-- ══════════ ROW 6 — ListView ══════════ -->
        <Border Grid.Row="5"
                ClipToBounds="True"
                BorderThickness="1.5"
                BorderBrush="#2E2B4A" Grid.ColumnSpan="2" Margin="0,14,0,0" Grid.RowSpan="2">
            <ListView BorderBrush="#CCCCCC"
                      BorderThickness="1"
                      FontSize="13"
                      FontFamily="Segoe UI"
                      ItemsSource="{Binding DSHangThanhVienView}"
                      SelectedItem="{Binding SelectedHangThanhVien}">

                <ListView.View>
                    <GridView>

                        <!-- Mã NV -->
                        <GridViewColumn Header="Mã Hạng" Width="80">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding MaHang}"
                                               Foreground="#9490B0"
                                               FontSize="12"
                                               Padding="14,10"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Tên đăng nhập -->
                        <GridViewColumn Header="Tên Hàng" Width="180">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding TenHang}"
                                               Foreground="#7C5CFC"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Padding="14,10"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Họ tên -->
                        <GridViewColumn Header="Phần trăm giảm giá" Width="160">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding PhanTramGiamGia}"
                                               Foreground="Black"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Padding="14,10"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Trạng Thái" Width="160">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding IsEnable}"
                                               Foreground="Black"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               Padding="14,10"
                                               Name="TrangThaiText"/>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsEnable}" Value="True">
                                            <Setter TargetName="TrangThaiText" Property="Text" Value="Đang Hoạt Động"/>
                                            <Setter TargetName="TrangThaiText" Property="Foreground" Value="#16A34A"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsEnable}" Value="False">
                                            <Setter TargetName="TrangThaiText" Property="Text" Value="Ngưng Hoạt Động"/>
                                            <Setter TargetName="TrangThaiText" Property="Foreground" Value="#DC2626"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>

                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                    </GridView>
                </ListView.View>

            </ListView>
        </Border>

        <!-- ══════════ ROW 8 — Buttons ══════════ -->
        <Grid Grid.Row="8" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
            </Grid.ColumnDefinitions>

            <!-- Thêm -->
            <Button Grid.Column="0"
                    Content="➕  Thêm"
                    Height="40"
                    Command="{Binding ThemCommand}">

                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#16A34A" Offset="0"/>
                        <GradientStop Color="#4ADE80" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>
            </Button>

            <!-- Sửa -->
            <Button Grid.Column="2"
                    Content="✏  Sửa"
                    Height="40"
                    Command="{Binding SuaCommand}"
                    >
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1D4ED8" Offset="0"/>
                        <GradientStop Color="#38BDF8" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>

            </Button>

            <!-- Khóa tài khoản -->
            <Button Grid.Column="4"
                    Height="40"
                    Command="{Binding NgungHoatDongHangCommand}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="❌  " VerticalAlignment="Center"/>
                    <TextBlock Text="Ngưng hoạt động hạng" VerticalAlignment="Center"/>
                </StackPanel>

                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#DC2626" Offset="0"/>
                        <GradientStop Color="#F87171" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>

            </Button>

            <Button Grid.Column="6"
                    Height="40"
                    Command="{Binding HoatDongTroLaiCommand}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔄  " VerticalAlignment="Center"/>
                    <TextBlock Text="Hoạt động trở lại" VerticalAlignment="Center"/>
                </StackPanel>

                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0891B2" Offset="0"/>
                        <GradientStop Color="#22D3EE" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>

            </Button>



        </Grid>

    </Grid>
</UserControl>
