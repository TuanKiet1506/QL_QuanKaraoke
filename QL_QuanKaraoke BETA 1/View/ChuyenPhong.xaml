<Window x:Class="QL_QuanKaraoke_BETA_1.View.ChuyenPhong"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QL_QuanKaraoke_BETA_1"
        mc:Ignorable="d"
        Title="Chuyển Phòng"
        Height="630" Width="560"
        WindowStartupLocation="CenterScreen"
        Background="White"
        ResizeMode="NoResize" DataContext="{StaticResource ChuyenPhongVM}"
        Name="ChuyenPhongWD">

    <Grid Margin="32,28,32,28">
        <Grid.RowDefinitions>
            <!-- Tiêu đề -->
            <RowDefinition Height="Auto"/>
            <!-- Gap -->
            <RowDefinition Height="24"/>
            <!-- Phòng hiện tại -->
            <RowDefinition Height="Auto"/>
            <!-- Gap -->
            <RowDefinition Height="20"/>
            <!-- Mũi tên chuyển -->
            <RowDefinition Height="Auto"/>
            <!-- Gap -->
            <RowDefinition Height="20"/>
            <!-- Phòng mới -->
            <RowDefinition Height="Auto"/>
            <!-- Gap -->
            <RowDefinition Height="28"/>
            <!-- Nút Xác nhận -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══════════ ROW 0 — Tiêu đề ══════════ -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
            <Border Background="#F88888" CornerRadius="10"
                    Padding="10,8" Margin="0,0,12,0">
                <TextBlock Text="🔄" FontSize="18"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Chuyển Phòng"
                           Foreground="#F88888"
                           FontSize="20"
                           FontWeight="Bold"/>
                <TextBlock Text="Di chuyển khách sang phòng khác"
                           Foreground="Black"
                           FontSize="11"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="2"
                Background="#FFF3F3"
                BorderThickness="1.5"
                BorderBrush="#F88888"
                Padding="20,16">
            <StackPanel>

                <!-- Nhãn section -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                    <TextBlock Text="Phòng Hiện Tại"
                               Foreground="Red"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 3 ô thông tin -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Tên phòng -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Tên phòng"
                                   Foreground="#222222"
                                   FontSize="11"
                                   Margin="0,0,0,6"/>
                        <Border Background="White"
                                Height="25"
                                Margin="0,0,0,14"
                                BorderBrush="#CCCCCC"
                                BorderThickness="1">
                            <Grid>
                                <TextBox
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="Black"
                                         FontSize="14"
                                         VerticalContentAlignment="Center"
                                         Padding="4,0,10,0"
                                         IsReadOnly="True"
                                         Text="{Binding PhongCu.TenPhong}"/>
                            </Grid>
                        </Border>

                    </StackPanel>

                    <!-- Sức chứa -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Sức chứa"
                                   Foreground="#222222"
                                   FontSize="11"
                                   Margin="0,0,0,6"/>
                        <Border Background="White"
                                Height="25"
                                Margin="0,0,0,14"
                                BorderBrush="#CCCCCC"
                                BorderThickness="1">
                            <Grid>
                                <TextBox
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="Black"
                                         FontSize="14"
                                         VerticalContentAlignment="Center"
                                         Padding="4,0,10,0"
                                         IsReadOnly="True"
                                         Text="{Binding PhongCu.SucChua}"/>
                            </Grid>
                        </Border>

                    </StackPanel>

                    <!-- Loại phòng -->
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Loại phòng"
                                   Foreground="#222222"
                                   FontSize="11"
                                   Margin="0,0,0,6"/>
                        <Border Background="White"
                                Height="25"
                                Margin="0,0,0,14"
                                BorderBrush="#CCCCCC"
                                BorderThickness="1">
                            <Grid>
                                <TextBox
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="Black"
                                         FontSize="14"
                                         VerticalContentAlignment="Center"
                                         Padding="4,0,10,0"
                                         IsReadOnly="True"
                                         Text="{Binding PhongCu.LoaiPhong.TenLoai}"/>
                            </Grid>
                        </Border>

                    </StackPanel>

                </Grid>
            </StackPanel>
        </Border>

        <!-- ══════════ ROW 4 — Mũi tên ══════════ -->
        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Center">
            <Border Background="#FFF3F3" CornerRadius="20"
                    Padding="18,8" BorderBrush="Red" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⬇" FontSize="14"
                               Foreground="#7C5CFC"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <TextBlock Text="Chuyển sang phòng"
                               Foreground="Black"
                               FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- ══════════ ROW 6 — Card: Phòng Mới ══════════ -->
        <Border Grid.Row="6"
                Background="#FFF3F3"
                BorderThickness="1.5"
                BorderBrush="#F88888"
                Padding="20,16">
            <StackPanel>

                <!-- Nhãn section -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                    <TextBlock Text="Phòng Mới"
                               Foreground="DarkGreen"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- ComboBox chọn phòng -->
                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="Chọn phòng"
                               Foreground="Black"
                               FontSize="11"
                               Margin="0,0,0,6"/>
                    <ComboBox
                              Height="35"
                              ItemsSource="{Binding DanhSachPhongTrong}"
                              SelectedItem="{Binding SelectedPhongMoi, UpdateSourceTrigger=PropertyChanged}"
                              DisplayMemberPath="TenPhong">
                        

                    </ComboBox>
                    <!-- Style sẽ được thêm sau -->
                </StackPanel>

                <!-- 3 ô thông tin phòng mới (readonly, tự điền khi chọn combobox) -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Tên phòng -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Tên phòng"
                                   Foreground="Black"
                                   FontSize="11"
                                   Margin="0,0,0,6"/>
                        <Border Background="White"
                                Height="25"
                                Margin="0,0,0,14"
                                BorderBrush="#CCCCCC"
                                BorderThickness="1">
                            <Grid>
                                <TextBox
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="Black"
                                         FontSize="14"
                                         VerticalContentAlignment="Center"
                                         Padding="4,0,10,0"
                                         IsReadOnly="True"
                                         Text="{Binding SelectedPhongMoi.TenPhong}"/>
                            </Grid>
                        </Border>

                    </StackPanel>

                    <!-- Sức chứa -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Sức chứa"
                                   Foreground="Black"
                                   FontSize="11"
                                   Margin="0,0,0,6"/>
                        <Border Background="White"
                                Height="25"
                                Margin="0,0,0,14"
                                BorderBrush="#CCCCCC"
                                BorderThickness="1">
                            <Grid>
                                <TextBox
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="Black"
                                         FontSize="14"
                                         VerticalContentAlignment="Center"
                                         Padding="4,0,10,0"
                                         Style="{StaticResource TextBoxTheme}"
                                         IsReadOnly="True"
                                         Text="{Binding SelectedPhongMoi.SucChua}"/>
                            </Grid>
                        </Border>

                    </StackPanel>

                    <!-- Loại phòng -->
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Loại phòng"
                                   Foreground="Black"
                                   FontSize="11"
                                   Margin="0,0,0,6"/>
                        <Border Background="White"
                                Height="25"
                                Margin="0,0,0,14"
                                BorderBrush="#CCCCCC"
                                BorderThickness="1">
                            <Grid>
                                <TextBox
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="Black"
                                         FontSize="14"
                                         VerticalContentAlignment="Center"
                                         Padding="4,0,10,0"
                                         Style="{StaticResource TextBoxTheme}"
                                         IsReadOnly="True"
                                         Text="{Binding SelectedPhongMoi.LoaiPhong.TenLoai}"/>
                            </Grid>
                        </Border>

                    </StackPanel>

                </Grid>
            </StackPanel>
        </Border>

        <!-- ══════════ ROW 8 — Nút Xác Nhận ══════════ -->
                        <Button Height="46"
                                Cursor="Hand"
                                BorderThickness="0"
                                Grid.Row="8"
                                Command="{Binding XacNhanChuyenPhongCommand}"
                                CommandParameter="{Binding ElementName=ChuyenPhongWD}">

            <Button.Template>
                <ControlTemplate TargetType="Button">

                    <Border x:Name="LoginBorder"
                                            CornerRadius="8"
                                            Height="46">

                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FFE01A38" Offset="0"/>
                                <GradientStop Color="#FFD81D1D" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>

                        <TextBlock Text="✔  Xác Nhận Chuyển Phòng"
                                                   Foreground="White"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   FontFamily="Segoe UI"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>

                    </Border>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="LoginBorder"
                                                    Property="Opacity"
                                                    Value="0.88"/>
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="LoginBorder"
                                                    Property="Opacity"
                                                    Value="0.72"/>
                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Button.Template>

        </Button>

    </Grid>
</Window>
