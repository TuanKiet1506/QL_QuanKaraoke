<UserControl x:Class="QL_QuanKaraoke_BETA_1.View.QL_BangGiaUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QL_QuanKaraoke_BETA_1"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" DataContext="{StaticResource QL_BangGiaVM}">
    <UserControl.Resources>

        <!-- ══════════════════════════════════════
             LISTVIEW — COLUMN HEADER
        ══════════════════════════════════════ -->
        <Style x:Key="HeaderStyle" TargetType="GridViewColumnHeader">
            <Setter Property="Background"           Value="#22203A"/>
            <Setter Property="Foreground"           Value="#9490B0"/>
            <Setter Property="FontSize"             Value="11"/>
            <Setter Property="FontWeight"           Value="SemiBold"/>
            <Setter Property="Padding"              Value="14,10"/>
            <Setter Property="BorderThickness"      Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══════════════════════════════════════
             LISTVIEW — ROW (ListViewItem)
        ══════════════════════════════════════ -->
        <Style x:Key="NvRowStyle" TargetType="ListViewItem">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#F0EEF8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="RowBorder"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0,0,0,1"
                                BorderBrush="#1E1C31"
                                Padding="0,2">
                            <GridViewRowPresenter
                                Columns="{Binding Path=View.Columns,
                                          RelativeSource={RelativeSource AncestorType=ListView}}"
                                Content="{TemplateBinding Content}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RowBorder" Property="Background" Value="#22203A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="RowBorder" Property="Background" Value="#2A2740"/>
                                <Setter TargetName="RowBorder" Property="BorderBrush" Value="#7C5CFC"/>
                                <Setter TargetName="RowBorder" Property="BorderThickness" Value="0,0,0,1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══════════════════════════════════════
             LISTVIEW CHÍNH
        ══════════════════════════════════════ -->
        <Style x:Key="NvListView" TargetType="ListView">
            <Setter Property="Background"       Value="#1A1829"/>
            <Setter Property="BorderThickness"  Value="1.5"/>
            <Setter Property="BorderBrush"      Value="#2E2B4A"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility"   Value="Auto"/>
        </Style>

        <!-- ══════════════════════════════════════
             BADGE: TRẠNG THÁI
             TrangThai = 1  → Đang làm việc (xanh)
             TrangThai = 0  → Nghỉ việc / Bị khóa (xem ChucVu/flag)
             → Dùng DataTrigger trực tiếp trong CellTemplate
        ══════════════════════════════════════ -->

    </UserControl.Resources>

    <!-- ══════════════════════════════════════════════════════════
         ROOT
    ══════════════════════════════════════════════════════════ -->
    <Grid Margin="24,20,24,20">
        <Grid.RowDefinitions>
            <!-- Tiêu đề -->
            <RowDefinition Height="Auto"/>
            <!-- Gap -->
            <RowDefinition Height="20"/>
            <!-- Input: HoTen + SoDienThoai -->
            <RowDefinition Height="Auto"/>
            <!-- Gap -->
            <RowDefinition Height="14"/>
            <!-- Toolbar: Filter + Search -->
            <RowDefinition Height="Auto"/>
            <!-- Gap -->
            <RowDefinition Height="14"/>
            <!-- ListView -->
            <RowDefinition Height="*"/>
            <!-- Gap -->
            <RowDefinition Height="14"/>
            <!-- Buttons -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══════════ ROW 0 — Tiêu đề ══════════ -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="💰" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#F88888"/>
            <TextBlock Text="Quản Lý Bảng Giá"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- ══════════ ROW 2 — Input HoTen + SoDienThoai ══════════ -->
        <Border Grid.Row="2"
                Background="#1E1C31"
                CornerRadius="14"
                BorderThickness="1.5"
                BorderBrush="#2E2B4A"
                Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="32"/>
                </Grid.ColumnDefinitions>

                <!-- Họ tên -->
                <TextBlock Grid.Column="0"
                           Text="Loại Phòng"
                           Foreground="#9490B0"
                           FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <Border Background="#353340"
                        CornerRadius="8"
                        Height="25"
                        Margin="0,0,0,0" 
                        Grid.Column="1"
                        >
                    <Grid>
                        <TextBox
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#E6E6E6"
                             FontSize="14"
                             VerticalContentAlignment="Center"
                             Padding="4,0,10,0"
                             Style="{StaticResource TextBoxTheme}"
                             IsReadOnly="True"
                             Text="{Binding SelectedBangGia.LoaiPhong.TenLoai}"
                     />
                    </Grid>
                </Border>

                <!-- Số điện thoại -->
                <TextBlock Grid.Column="3"
                           Text="Đơn Giá/ Giờ"
                           Foreground="#9490B0"
                           FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <Border Background="#353340"
                           CornerRadius="8"
                           Height="25"
                           Margin="0,0,0,0" 
                           Grid.Column="4"
                                           >
                    <Grid>
                        <TextBox
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="#E6E6E6"
                                FontSize="14"
                                VerticalContentAlignment="Center"
                                Padding="4,0,10,0"
                                Style="{StaticResource TextBoxTheme}"
                                IsReadOnly="True"
                                Text="{Binding SelectedBangGia.Gia, StringFormat={}{0:N0}đ}"
                                   />
                    </Grid>
                </Border>

            </Grid>
        </Border>

        <!-- ══════════ ROW 4 — Filter + Search ══════════ -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>


        </Grid>

        <!-- ══════════ ROW 6 — ListView ══════════ -->
        <Border Grid.Row="6"
                CornerRadius="14"
                ClipToBounds="True"
                BorderThickness="1.5"
                BorderBrush="#2E2B4A">
            <ListView Style="{StaticResource NvListView}"
                      ItemContainerStyle="{StaticResource NvRowStyle}"
                      ItemsSource="{Binding DSBangGia}"
                      SelectedItem="{Binding SelectedBangGia}">

                <ListView.View>
                    <GridView ColumnHeaderContainerStyle="{StaticResource HeaderStyle}">

                        <!-- Mã NV -->
                        <GridViewColumn Header="Loại Phòng" Width="85">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding LoaiPhong.TenLoai}"
                                               Foreground="#9490B0"
                                               FontSize="12"
                                               Padding="14,10"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Tên đăng nhập -->
                        <GridViewColumn Header="Giờ bắt đầu" Width="180">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding GioBatDau}"
                                               Foreground="#7C5CFC"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Padding="14,10"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Họ tên -->
                        <GridViewColumn Header="Giờ kết thúc" Width="180">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding GioKetThuc}"
                                               Foreground="#F0EEF8"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Padding="14,10"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        
                        
                        <GridViewColumn Header="Đơn giá" Width="180">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Gia, StringFormat={}{0:N0}đ}"
                                               Foreground="#F0EEF8"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Padding="14,10"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Số điện thoại -->



                    </GridView>
                </ListView.View>

            </ListView>
        </Border>

        <!-- ══════════ ROW 8 — Buttons ══════════ -->
        <Grid Grid.Row="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
            </Grid.ColumnDefinitions>

            <!-- Thêm -->
            <Button Grid.Column="0"
                    Content="💰  Sửa Giá"
                    Height="40"
                    Command="{Binding SuaGiaCommand}">

                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#059669" Offset="0"/>
                        <GradientStop Color="#34D399" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>
            </Button>

            <!-- Sửa -->
            <Button Grid.Column="2"
                    Content="🕒  Sửa Khung Giờ"
                    Height="40"
                    Command="{Binding SuaKhungGioCommand}"
                    >
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#D97706" Offset="0"/>
                        <GradientStop Color="#FBBF24" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>

            </Button>

            <!-- Khóa tài khoản -->
            <Button Grid.Column="4"
                    Height="40"
                    Command="{Binding KhoiPhucMacDinhCommand}"
                    >
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔄  " VerticalAlignment="Center"/>
                    <TextBlock Text="Khôi Phục Mặc Định" VerticalAlignment="Center"/>
                </StackPanel>

                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#7C3AED" Offset="0"/>
                        <GradientStop Color="#A78BFA" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>

            </Button>



        </Grid>

    </Grid>
</UserControl>
