<UserControl x:Class="QL_QuanKaraoke_BETA_1.View.QL_HeThongUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QL_QuanKaraoke_BETA_1"
             mc:Ignorable="d" 
             d:DesignHeight="550" d:DesignWidth="950" DataContext="{StaticResource QLHeThongVM}"
             Background="White">
    <UserControl.Resources>





    </UserControl.Resources>

    <Grid Margin="24,20,24,20">
        <Grid.RowDefinitions>
            <!-- Tiêu đề -->
            <RowDefinition Height="Auto"/>
            <!-- Gap -->
            <RowDefinition Height="20"/>
            <!-- Input: HoTen + SoDienThoai -->
            <RowDefinition Height="Auto"/>
            <!-- Gap -->
            <RowDefinition Height="14"/>
            <!-- Toolbar: Filter + Search -->
            <RowDefinition Height="Auto"/>
            <!-- Gap -->
            <RowDefinition Height="14"/>
            <!-- ListView -->
            <RowDefinition Height="*"/>
            <!-- Gap -->
            <RowDefinition Height="14"/>
            <!-- Buttons -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══════════ ROW 0 — Tiêu đề ══════════ -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="⚙️" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"
                       Foreground="#F88888"/>
            <TextBlock Text="Quản Lý Hệ Thống"
                       Foreground="#F88888"
                       FontSize="22"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- ══════════ ROW 2 — Input HoTen + SoDienThoai ══════════ -->
        <Border Grid.Row="2"
                Background="#F9F9F9"
                BorderThickness="1"
                BorderBrush="#DDDDDD"
                Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="160"/>
                </Grid.ColumnDefinitions>

                <!-- Họ tên -->
                <TextBlock Grid.Column="0"
                           Text="Nhân viên"
                           Foreground="Black"
                           FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <Border Background="White"
                        Height="25"
                        Margin="0,0,0,0" 
                        Grid.Column="1"
                        BorderBrush="#CCCCCC"
                        BorderThickness="1"
                        >
                    <Grid>
                        <TextBox
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="Black"
                             FontSize="14"
                             VerticalContentAlignment="Center"
                             Padding="4,0,10,0"
                             IsReadOnly="True"
                             Text="{Binding TenNhanVien}"
                     />
                    </Grid>
                </Border>

                <!-- Số điện thoại -->
                <TextBlock Grid.Column="3"
                           Text="Hành động"
                           Foreground="Black"
                           FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <Border Background="White"
                           Height="25"
                           Margin="0,0,0,0" 
                           Grid.Column="4"
                        BorderBrush="#CCCCCC"
                        BorderThickness="1"
                                           >
                    <Grid>
                        <TextBox
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="Black"
                                FontSize="14"
                                VerticalContentAlignment="Center"
                                Padding="4,0,10,0"
                                IsReadOnly="True"
                                Text="{Binding HanhDong}"
                                   />
                    </Grid>
                </Border>

                <!-- Chức vụ -->
                <TextBlock Grid.Column="6"
                           Text="Thời gian"
                           Foreground="Black"
                           FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <Border Background="White"
                        Height="25"
                        Margin="0,0,0,0" 
                        Grid.Column="7"
                         BorderBrush="#CCCCCC"
                        BorderThickness="1">
                    <Grid>
                        <TextBox
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="Black"
                         FontSize="14"
                         VerticalContentAlignment="Center"
                         Padding="4,0,10,0"
                         IsReadOnly="True"
                         Text="{Binding ThoiGian}"
                         />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ══════════ ROW 4 — Filter + Search ══════════ -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ComboBox lọc trạng thái -->
            <DatePicker Grid.Column="0"
                      Height="38"
                      
                      SelectedDate="{Binding NgayLoc}"/>

            <!-- TextBox tìm kiếm -->
            <Grid Grid.Column="2">
                <Border Background="White"
                Height="46"
                Margin="0"
                        BorderBrush="#CCCCCC"
                        BorderThickness="1">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Width="18"
                       Height="18"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Text="🔍"/>

                        <TextBox Grid.Column="1" Text="{Binding TuKhoa, UpdateSourceTrigger=PropertyChanged}"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="Black"
                         FontSize="14"
                         VerticalContentAlignment="Center"
                         Padding="4,0,10,0"
                         Width="638"/>
                    </Grid>

                </Border>
            </Grid>
        </Grid>

        <!-- ══════════ ROW 6 — ListView ══════════ -->
        <Border Grid.Row="6"
                ClipToBounds="True"
                BorderThickness="1.5"
                BorderBrush="#2E2B4A">
            <ListView BorderBrush="#CCCCCC"
                      BorderThickness="1"
                      FontSize="13"
                      FontFamily="Segoe UI"
                      ItemsSource="{Binding DsSystemLogView, UpdateSourceTrigger=PropertyChanged}"
                      SelectedItem="{Binding SelectedLog}">

                <ListView.View>
                    <GridView >

                        <!-- Mã NV -->
                        <GridViewColumn Header="Nhân viên" Width="150">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding NhanVien.HoTen}"
                                               Foreground="OrangeRed"
                                               FontSize="12"
                                               Padding="14,10"
                                               FontWeight="Bold"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Tên đăng nhập -->
                        <GridViewColumn Header="Hành động" Width="120">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding HanhDong}"
                                               Foreground="#7C5CFC"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Padding="14,10"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Họ tên -->
                        <GridViewColumn Header="Thời gian" Width="150">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding ThoiGian}"
                                               Foreground="Black"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Padding="14,10"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Số điện thoại -->
                        <GridViewColumn Header="Mô tả" Width="480">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding MoTa}"
                                               Foreground="Black"
                                               FontSize="12"
                                               Padding="14,10"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>


                    </GridView>
                </ListView.View>

            </ListView>
        </Border>

        <!-- ══════════ ROW 8 — Buttons ══════════ -->
        <Grid Grid.Row="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
            </Grid.ColumnDefinitions>


            <Button Grid.Column="0"
                    Height="40"
                    Width="350"
                    Command="{Binding XoaLogCommand}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="❌  " VerticalAlignment="Center"/>
                    <TextBlock Text="Xóa" VerticalAlignment="Center"/>
                </StackPanel>

                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#DC2626" Offset="0"/>
                        <GradientStop Color="#F87171" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>

            </Button>


        </Grid>

    </Grid>
</UserControl>
