<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===================== MÀU SẮC CONTROL BAR ===================== -->
    <SolidColorBrush x:Key="CB_BrushBtnHover"   Color="#3A3750"/>
    <SolidColorBrush x:Key="CB_BrushCloseHover" Color="#E74C3C"/>
    <SolidColorBrush x:Key="CB_BrushClosePressColor" Color="#C0392B"/>
    <SolidColorBrush x:Key="CB_BrushIconNormal" Color="#9B99B5"/>
    <SolidColorBrush x:Key="CB_BrushIconHover"  Color="#FFFFFF"/>

    <Style x:Key="BaseControlButtonStyle" TargetType="Button">
        <Setter Property="Width"           Value="38"/>
        <Setter Property="Height"          Value="38"/>
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Focusable"       Value="False"/>
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="PART_Bg"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_Bg" Property="Background"
                                    Value="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="PART_Bg" Property="Opacity" Value="0.7"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== NÚT ĐÓNG (X) ===================== -->
    <Style x:Key="CloseButtonStyle" TargetType="Button"
           BasedOn="{StaticResource BaseControlButtonStyle}">
        <!-- Tag dùng làm màu hover background, bind trong ControlTemplate -->
        <Setter Property="Tag"     Value="{StaticResource CB_BrushCloseHover}"/>
        <Setter Property="ToolTip" Value="Đóng"/>
        <Setter Property="Content">
            <Setter.Value>
                <!-- Icon X -->
                <Viewbox Width="12" Height="12" Stretch="Uniform">
                    <Canvas Width="14" Height="14">
                        <Line X1="1" Y1="1" X2="13" Y2="13"
                              StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                            <Line.Stroke>
                                <SolidColorBrush x:Name="CloseIconBrush" Color="#9B99B5"/>
                            </Line.Stroke>
                        </Line>
                        <Line X1="13" Y1="1" X2="1" Y2="13"
                              StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                            <Line.Stroke>
                                <SolidColorBrush x:Name="CloseIconBrush2" Color="#9B99B5"/>
                            </Line.Stroke>
                        </Line>
                    </Canvas>
                </Viewbox>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Content">
                    <Setter.Value>
                        <Viewbox Width="12" Height="12" Stretch="Uniform">
                            <Canvas Width="14" Height="14">
                                <Line X1="1" Y1="1" X2="13" Y2="13"
                                      Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <Line X1="13" Y1="1" X2="1" Y2="13"
                                      Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Canvas>
                        </Viewbox>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ===================== NÚT THU NHỎ (-) ===================== -->
    <Style x:Key="MinimizeButtonStyle" TargetType="Button"
           BasedOn="{StaticResource BaseControlButtonStyle}">
        <Setter Property="Tag"     Value="{StaticResource CB_BrushBtnHover}"/>
        <Setter Property="ToolTip" Value="Thu nhỏ"/>
        <Setter Property="Content">
            <Setter.Value>
                <Viewbox Width="12" Height="12" Stretch="Uniform">
                    <Canvas Width="14" Height="14">
                        <Line X1="2" Y1="7" X2="12" Y2="7"
                              Stroke="#9B99B5" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </Canvas>
                </Viewbox>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Content">
                    <Setter.Value>
                        <Viewbox Width="12" Height="12" Stretch="Uniform">
                            <Canvas Width="14" Height="14">
                                <Line X1="2" Y1="7" X2="12" Y2="7"
                                      Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Canvas>
                        </Viewbox>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ===================== NÚT PHÓNG TO / RESTORE ===================== -->
    <Style x:Key="MaximizeButtonStyle" TargetType="Button"
           BasedOn="{StaticResource BaseControlButtonStyle}">
        <Setter Property="Tag"     Value="{StaticResource CB_BrushBtnHover}"/>
        <Setter Property="ToolTip" Value="Phóng to"/>
        <Setter Property="Content">
            <Setter.Value>
                <!-- Icon hình vuông rỗng -->
                <Viewbox Width="12" Height="12" Stretch="Uniform">
                    <Canvas Width="14" Height="14">
                        <Rectangle Canvas.Left="1" Canvas.Top="1"
                                   Width="12" Height="12" RadiusX="1" RadiusY="1"
                                   Stroke="#9B99B5" StrokeThickness="2" Fill="Transparent"/>
                    </Canvas>
                </Viewbox>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Content">
                    <Setter.Value>
                        <Viewbox Width="12" Height="12" Stretch="Uniform">
                            <Canvas Width="14" Height="14">
                                <Rectangle Canvas.Left="1" Canvas.Top="1"
                                           Width="12" Height="12" RadiusX="1" RadiusY="1"
                                           Stroke="White" StrokeThickness="2" Fill="Transparent"/>
                            </Canvas>
                        </Viewbox>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ControlBarPanelStyle" TargetType="StackPanel">
        <Setter Property="Orientation"          Value="Horizontal"/>
        <Setter Property="HorizontalAlignment"  Value="Right"/>
        <Setter Property="VerticalAlignment"    Value="Center"/>
        <Setter Property="Margin"               Value="0,0,8,0"/>
    </Style>

</ResourceDictionary>