            </DataTemplate>
            
            <DataTemplate DataType="{x:Type viewmodel:QL_BangGiaViewModel}">
                <local:QL_BangGiaUC/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type viewmodel:QL_HangThanhVienViewModel}">
                <local:QL_HangThanhVienUC/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type viewmodel:QL_DichVuViewModel}">
                <local:QL_DichVuUC/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type viewmodel:QL_HeThongViewModel}">
                <local:QL_HeThongUC/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type viewmodel:QL_DangNhapViewModel}">
                <local:QL_DangNhap/>
            </DataTemplate>

        </ResourceDictionary>
    </Application.Resources>
    
</Application>
