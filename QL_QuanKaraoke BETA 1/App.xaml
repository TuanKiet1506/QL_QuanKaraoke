                <ResourceDictionary Source="/Theme/ButtonDarkTheme.xaml"/>
                <ResourceDictionary Source="/Theme/ControlBarDarkTheme.xaml"/>
                <ResourceDictionary Source="/Theme/MenuButtonDarkTheme.xaml"/>
                <ResourceDictionary Source="/Theme/TextBoxDarkTheme.xaml"/>
                <ResourceDictionary Source="/Theme/PasswordBoxDarkTheme.xaml"/>
                <ResourceDictionary Source="/Theme/ComboboxDarkTheme.xaml"/>
                <ResourceDictionary Source="/Theme/DatePickerDarkTheme.xaml"/>

            </ResourceDictionary.MergedDictionaries>

            <DataTemplate DataType="{x:Type viewmodel:TrangChuViewModel}">
                <local:TrangChuUC/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type viewmodel:DatPhongViewModel}">
                <local:DatPhongUC/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type viewmodel:QL_NhanVienViewModel}">
                <local:QL_NHANVIENUC/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type viewmodel:QL_KhachHangViewModel}">
